<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ site.name }} Docs{% endblock %}</title>
  <meta name="description" content="{% block description %}{{ site.name }} — Enterprise-grade CSS design system built on CUBE CSS and Every Layout.{% endblock %}">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/src/styles/main.css">
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <div class="sidebar" style="--sidebar-target-width: 17rem; --sidebar-content-min-width: 55%;">
    <aside class="padding-m background-neutral-900 color-neutral-50 flow" aria-label="Site navigation" style="--flow-space: var(--space-m);">
      <div class="padding-b-s" style="border-block-end: 1px solid var(--color-neutral-700);">
        <a href="/" class="text-no-underline color-neutral-50" aria-label="{{ site.name }} home">
          <strong class="heading-m">{{ site.name }}</strong>
        </a>
        <span class="badge" style="margin-inline-start: var(--space-xs);">v{{ site.version }}</span>
      </div>

      <nav aria-label="Documentation" class="docs-nav flow" style="--flow-space: var(--space-m);">
        {% for section in nav %}
        <div>
          <h2 class="heading-xs text-mono" style="color: var(--color-neutral-500); margin-block-end: var(--space-xs);">{{ section.title }}</h2>
          <ul class="flow" role="list" style="--flow-space: 0.25rem; list-style: none; padding: 0; margin: 0;">
            {% for item in section.items %}
            <li>
              <a href="{{ item.href }}" class="text-s text-no-underline color-neutral-300" style="display: block; padding: 0.2rem var(--space-xs); border-radius: var(--border-radius-s);">{{ item.label }}</a>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </nav>
    </aside>

    <main id="main" class="padding-l wrapper">
      {% block content %}{% endblock %}
    </main>
  </div>

  <script>
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    document.querySelectorAll('aside a[href]').forEach(a => {
      const href = a.getAttribute('href').replace(/\/$/, '') || '/';
      if (href === path) {
        a.setAttribute('aria-current', 'page');
      }
    });
  </script>
</body>
</html>
