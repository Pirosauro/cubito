<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ site.name }} Docs{% endblock %}</title>
  <meta name="description" content="{% block description %}{{ site.name }} — Enterprise-grade CSS design system built on CUBE CSS and Every Layout.{% endblock %}">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/src/styles/main.css">
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <div class="sidebar" style="--sidebar-content-min-width: 55%;">
    <aside class="padding-m background-neutral-900 color-neutral-50 flow" aria-label="Site navigation">
      <div style="display: inline-flex; align-items: center;">
        <a href="/" class="text-no-underline color-neutral-50" aria-label="{{ site.name }} home">
          <strong class="heading-m">{{ site.name }}</strong>
        </a>
        <span class="badge margin-x-xs">v{{ site.version }}</span>
      </div>

      <nav aria-label="Documentation" class="navigation padding-y-s flow" style="--flow-space: var(--space-s);">
        {% for section in nav %}
        <div>
          <h2 class="heading-s text-mono">{{ section.title }}</h2>
          <ul class="margin-y-xs" role="list">
            {% for item in section.items %}
            <li>
              <a href="{{ item.href }}">{{ item.label }}</a>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </nav>
    </aside>

    <main id="main" class="padding-l wrapper">
      {% block content %}{% endblock %}
    </main>
  </div>

  <script>
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    document.querySelectorAll('aside a[href]').forEach(a => {
      const href = a.getAttribute('href').replace(/\/$/, '') || '/';
      if (href === path) {
        a.setAttribute('aria-current', 'page');
      }
    });
  </script>
</body>
</html>
