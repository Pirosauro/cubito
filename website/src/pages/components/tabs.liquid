  &lt;/div&gt;
  &lt;div role=&quot;tabpanel&quot; id=&quot;panel2-billing&quot; aria-labelledby=&quot;tab2-billing&quot; hidden&gt;
    &lt;p&gt;Manage your subscription plan, view invoices, and update your payment method.&lt;/p&gt;
  &lt;/div&gt;
  &lt;div role=&quot;tabpanel&quot; id=&quot;panel2-security&quot; aria-labelledby=&quot;tab2-security&quot; hidden&gt;
