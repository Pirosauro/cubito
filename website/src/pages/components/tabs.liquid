    &lt;button role=&quot;tab&quot; id=&quot;tab3-shipping&quot; aria-controls=&quot;panel3-shipping&quot; aria-selected=&quot;false&quot; tabindex=&quot;-1&quot;&gt;Shipping&lt;/button&gt;
    &lt;button role=&quot;tab&quot; id=&quot;tab3-returns&quot; aria-controls=&quot;panel3-returns&quot; aria-selected=&quot;false&quot; tabindex=&quot;-1&quot;&gt;Returns&lt;/button&gt;
  &lt;/div&gt;

