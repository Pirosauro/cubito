    </details>
  </section>

  <section>
    <h2 class="heading-l">Tokens</h2>
    <table class="">
      <thead>
        <tr>
          <th>Token</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>--tabs-accent</code></td>
          <td><code>var(--color-brand)</code></td>
          <td>Active tab text colour and underline indicator colour.</td>
        </tr>
        <tr>
          <td><code>--tabs-tab-padding</code></td>
          <td><code>var(--space-xs) var(--space-s)</code></td>
          <td>Inner padding of each tab button.</td>
        </tr>
        <tr>
          <td><code>--tabs-indicator-height</code></td>
          <td><code>0.1875rem</code></td>
          <td>Thickness of the active underline indicator (default variant).</td>
        </tr>
        <tr>
          <td><code>--tabs-border</code></td>
          <td><code>solid var(--border-s) var(--color-neutral-200)</code></td>
          <td>Border beneath the tablist.</td>
        </tr>
        <tr>
          <td><code>--tabs-panel-padding</code></td>
          <td><code>var(--space-m) 0</code></td>
          <td>Padding inside each tabpanel.</td>
        </tr>
        <tr>
          <td><code>--tabs-background</code></td>
          <td><code>transparent</code></td>
          <td>Background of the tablist.</td>
        </tr>
        <tr>
          <td><code>--tabs-radius</code></td>
          <td><code>var(--border-radius-m)</code></td>
          <td>Corner radius used by the pills and lifted variants.</td>
        </tr>
      </tbody>
    </table>
  </section>

</article>

<script>
document.querySelectorAll('.tabs [role="tab"]').forEach(tab => {
  tab.addEventListener('click', () => {
    const tabs = tab.closest('.tabs');
    tabs.querySelectorAll('[role="tab"]').forEach(t => {
      t.setAttribute('aria-selected', 'false');
      t.setAttribute('tabindex', '-1');
    });
    tabs.querySelectorAll('[role="tabpanel"]').forEach(p => p.hidden = true);
    tab.setAttribute('aria-selected', 'true');
    tab.removeAttribute('tabindex');
    tabs.querySelector('#' + tab.getAttribute('aria-controls')).hidden = false;
  });
});
</script>
{% endblock %}
