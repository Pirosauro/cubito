{% layout "layouts/base.liquid" %}
{% block title %}Toast — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/components/">Components</a></li>
        <li aria-current="page">Toast</li>
      </ol>
    </nav>
    <h1>Toast</h1>
    <p class="text-m color-neutral-600">Dismissible notification overlays that stack in a corner of the viewport. Variants cover success, error, warning, and info states.</p>
  </header>

  <div class="callout wide" data-variant="brand" role="note">
    <p>Render a single <code>.toast-region</code> once per page, just before <code>&lt;/body&gt;</code>. JavaScript inserts and removes individual <code>.toast</code> elements inside it. The region is an <code>aria-live</code> container so screen readers announce new toasts automatically.</p>
  </div>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Toast region markup</h2>
      <p>The region uses <code>aria-live="polite"</code> for non-critical messages (success, info, warning). Use <code>aria-live="assertive"</code> (or <code>role="alert"</code> on individual toasts) for error messages that require immediate attention.</p>
    
      <div class="">
  <div class="toast-region" style="position: static; max-width: 100%">
    <div class="toast" role="status">
      <p>Your changes have been saved.</p>
    </div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;toast-region&quot; style=&quot;position: static; max-width: 100%&quot;&gt;
    &lt;div class=&quot;toast&quot; role=&quot;status&quot;&gt;
      &lt;p&gt;Your changes have been saved.&lt;/p&gt;
    &lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Variants</h2>
      <p>Apply <code>data-variant</code> to individual <code>.toast</code> elements. Each variant sets its own background colour; text is always white for contrast.</p>
    
      <div class="">
  <div class="toast-region" style="position: static; max-width: 100%">
    <div class="toast" data-variant="success" role="status">
      <p>Order confirmed. Your items will arrive within 3 business days.</p>
    </div>
    <div class="toast" data-variant="error" role="alert">
      <p>Payment failed. Please check your card details and try again.</p>
    </div>
    <div class="toast" data-variant="warning" role="status">
      <p>Your session will expire in 5 minutes. Save your work.</p>
    </div>
    <div class="toast" data-variant="info" role="status">
      <p>A new version of the app is available. Refresh to update.</p>
    </div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;toast-region&quot; style=&quot;position: static; max-width: 100%&quot;&gt;
    &lt;div class=&quot;toast&quot; data-variant=&quot;success&quot; role=&quot;status&quot;&gt;
      &lt;p&gt;Order confirmed. Your items will arrive within 3 business days.&lt;/p&gt;
    &lt;/div&gt;
    &lt;div class=&quot;toast&quot; data-variant=&quot;error&quot; role=&quot;alert&quot;&gt;
      &lt;p&gt;Payment failed. Please check your card details and try again.&lt;/p&gt;
    &lt;/div&gt;
    &lt;div class=&quot;toast&quot; data-variant=&quot;warning&quot; role=&quot;status&quot;&gt;
      &lt;p&gt;Your session will expire in 5 minutes. Save your work.&lt;/p&gt;
    &lt;/div&gt;
    &lt;div class=&quot;toast&quot; data-variant=&quot;info&quot; role=&quot;status&quot;&gt;
      &lt;p&gt;A new version of the app is available. Refresh to update.&lt;/p&gt;
    &lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">With dismiss button</h2>
      <p>Add a <code>.toast__dismiss</code> button to let users close persistent toasts manually. Use <code>aria-label</code> on the button so screen reader users know what the action does.</p>
    
      <div class="">
  <div class="toast-region" style="position: static; max-width: 100%">
    <div class="toast" data-variant="success" role="status">
      <p>Profile updated successfully.</p>
      <button class="toast__dismiss" aria-label="Dismiss notification" onclick="this.closest('.toast').setAttribute('hidden', '')">×</button>
    </div>
    <div class="toast" data-variant="error" role="alert">
      <p>Unable to connect. Check your network and try again.</p>
      <button class="toast__dismiss" aria-label="Dismiss notification" onclick="this.closest('.toast').setAttribute('hidden', '')">×</button>
    </div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;toast-region&quot; style=&quot;position: static; max-width: 100%&quot;&gt;
    &lt;div class=&quot;toast&quot; data-variant=&quot;success&quot; role=&quot;status&quot;&gt;
      &lt;p&gt;Profile updated successfully.&lt;/p&gt;
      &lt;button class=&quot;toast__dismiss&quot; aria-label=&quot;Dismiss notification&quot; onclick=&quot;this.closest(&#x27;.toast&#x27;).setAttribute(&#x27;hidden&#x27;, &#x27;&#x27;)&quot;&gt;×&lt;/button&gt;
    &lt;/div&gt;
    &lt;div class=&quot;toast&quot; data-variant=&quot;error&quot; role=&quot;alert&quot;&gt;
      &lt;p&gt;Unable to connect. Check your network and try again.&lt;/p&gt;
      &lt;button class=&quot;toast__dismiss&quot; aria-label=&quot;Dismiss notification&quot; onclick=&quot;this.closest(&#x27;.toast&#x27;).setAttribute(&#x27;hidden&#x27;, &#x27;&#x27;)&quot;&gt;×&lt;/button&gt;
    &lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Interactive demo</h2>
      <p>Click the button to show a toast. The dismiss button inside it hides it again.</p>
    
      <div class="">
  <button onclick="document.getElementById('demo-toast').removeAttribute('hidden')">Show toast</button>
  <div class="toast-region" style="position: static; margin-block-start: 1rem">
    <div class="toast" data-variant="success" id="demo-toast" hidden>
      <p>Changes saved successfully.</p>
      <button class="toast__dismiss" aria-label="Dismiss" onclick="this.parentElement.setAttribute('hidden', '')">×</button>
    </div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;button onclick=&quot;document.getElementById(&#x27;demo-toast&#x27;).removeAttribute(&#x27;hidden&#x27;)&quot;&gt;Show toast&lt;/button&gt;
  &lt;div class=&quot;toast-region&quot; style=&quot;position: static; margin-block-start: 1rem&quot;&gt;
    &lt;div class=&quot;toast&quot; data-variant=&quot;success&quot; id=&quot;demo-toast&quot; hidden&gt;
      &lt;p&gt;Changes saved successfully.&lt;/p&gt;
      &lt;button class=&quot;toast__dismiss&quot; aria-label=&quot;Dismiss&quot; onclick=&quot;this.parentElement.setAttribute(&#x27;hidden&#x27;, &#x27;&#x27;)&quot;&gt;×&lt;/button&gt;
    &lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Placement</h2>
      <p>Control where the region is anchored with <code>data-position</code> on <code>.toast-region</code>. The default is <code>top-right</code>.</p>
      <table class="">
        <thead>
          <tr><th>Value</th><th>Description</th></tr>
        </thead>
        <tbody>
          <tr><td><code>top-right</code></td><td>Top-right corner (default).</td></tr>
          <tr><td><code>top-left</code></td><td>Top-left corner.</td></tr>
          <tr><td><code>top-center</code></td><td>Top edge, centred horizontally.</td></tr>
          <tr><td><code>bottom-right</code></td><td>Bottom-right corner.</td></tr>
          <tr><td><code>bottom-left</code></td><td>Bottom-left corner.</td></tr>
          <tr><td><code>bottom-center</code></td><td>Bottom edge, centred horizontally.</td></tr>
        </tbody>
      </table>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Tokens</h2>
      <table class="">
        <thead>
          <tr>
            <th>Token</th>
            <th>Default</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--toast-default-inset</code></td>
            <td><code>var(--space-s)</code></td>
            <td>Distance from the viewport edge (on <code>.toast-region</code>).</td>
          </tr>
          <tr>
            <td><code>--toast-default-width</code></td>
            <td><code>22rem</code></td>
            <td>Maximum width of the toast region.</td>
          </tr>
          <tr>
            <td><code>--toast-default-gap</code></td>
            <td><code>var(--space-xs)</code></td>
            <td>Gap between stacked toasts.</td>
          </tr>
          <tr>
            <td><code>--toast-default-background</code></td>
            <td><code>var(--color-neutral-900)</code></td>
            <td>Background of a neutral toast.</td>
          </tr>
          <tr>
            <td><code>--toast-default-color</code></td>
            <td><code>var(--color-neutral-50)</code></td>
            <td>Text colour of a neutral toast.</td>
          </tr>
          <tr>
            <td><code>--toast-default-border</code></td>
            <td><code>none</code></td>
            <td>Border shorthand.</td>
          </tr>
          <tr>
            <td><code>--toast-default-radius</code></td>
            <td><code>var(--border-radius-l)</code></td>
            <td>Corner radius.</td>
          </tr>
          <tr>
            <td><code>--toast-default-padding</code></td>
            <td><code>var(--space-xs) var(--space-s)</code></td>
            <td>Inner padding.</td>
          </tr>
          <tr>
            <td><code>--toast-default-shadow</code></td>
            <td>Layered drop shadow</td>
            <td>Box shadow applied to each toast.</td>
          </tr>
        </tbody>
      </table>
  
    </div>
  </section>

</article>
{% endblock %}
