{% layout "layouts/base.liquid" %}
{% block title %}Progress Bar — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="padding-y-m margin-y-m" style="border-block-end: 1px solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/components/">Components</a></li>
        <li aria-current="page">Progress Bar</li>
      </ol>
    </nav>
    <h1>Progress Bar</h1>
    <p class="text-l color-neutral-600">A labelled, accessible wrapper around the native <code>&lt;progress&gt;</code> element with theming and a visible percentage readout.</p>
  </header>

  <section>
    <h2 class="heading-l">With header</h2>
    <p>Wrap a <code>&lt;progress&gt;</code> in <code>.progress-bar</code> and add a <code>.progress-bar__header</code> containing a labelling span (linked via <code>aria-labelledby</code>) and an optional visible percentage. The percentage display is marked <code>aria-hidden="true"</code> because the label already conveys it.</p>
    
    <div class="padding-m margin-y-m background-neutral-50 border border-neutral-200">
<div class="progress-bar">
  <div class="progress-bar__header">
    <span id="pb-upload">Uploading files…</span>
    <span aria-hidden="true">72%</span>
  </div>
  <progress
    value="72"
    max="100"
    aria-labelledby="pb-upload"
    aria-valuenow="72"
    aria-valuemin="0"
    aria-valuemax="100"
  ></progress>
</div>
    </div>

    <details class="margin-y-s">
      <summary class="padding-s">Show code</summary>
      <pre class="padding-m background-neutral-900" style="overflow-x: auto;"><code>&lt;div class=&quot;progress-bar&quot;&gt;
  &lt;div class=&quot;progress-bar__header&quot;&gt;
    &lt;span id=&quot;pb-upload&quot;&gt;Uploading files…&lt;/span&gt;
    &lt;span aria-hidden=&quot;true&quot;&gt;72%&lt;/span&gt;
  &lt;/div&gt;
  &lt;progress
    value=&quot;72&quot;
    max=&quot;100&quot;
    aria-labelledby=&quot;pb-upload&quot;
    aria-valuenow=&quot;72&quot;
    aria-valuemin=&quot;0&quot;
    aria-valuemax=&quot;100&quot;
  &gt;&lt;/progress&gt;
&lt;/div&gt;</code></pre>
    </details>
  </section>

  <section>
    <h2 class="heading-l">Multiple states</h2>
    <p>Use <code>value</code> between 0 and <code>max</code> to reflect any completion level.</p>
    
    <div class="padding-m margin-y-m background-neutral-50 border border-neutral-200">
<div class="flow" style="--flow-space: var(--space-m)">
  <div class="progress-bar">
    <div class="progress-bar__header">
      <span id="pb-s1">Step 1 — Profile</span>
      <span aria-hidden="true">25%</span>
    </div>
    <progress value="25" max="100" aria-labelledby="pb-s1"></progress>
  </div>

  <div class="progress-bar">
    <div class="progress-bar__header">
      <span id="pb-s2">Step 2 — Payment</span>
      <span aria-hidden="true">60%</span>
    </div>
    <progress value="60" max="100" aria-labelledby="pb-s2"></progress>
  </div>

  <div class="progress-bar">
    <div class="progress-bar__header">
      <span id="pb-s3">Step 3 — Complete</span>
      <span aria-hidden="true">100%</span>
    </div>
    <progress value="100" max="100" aria-labelledby="pb-s3"></progress>
  </div>
</div>
    </div>

    <details class="margin-y-s">
      <summary class="padding-s">Show code</summary>
      <pre class="padding-m background-neutral-900" style="overflow-x: auto;"><code>&lt;div class=&quot;flow&quot; style=&quot;--flow-space: var(--space-m)&quot;&gt;
  &lt;div class=&quot;progress-bar&quot;&gt;
    &lt;div class=&quot;progress-bar__header&quot;&gt;
      &lt;span id=&quot;pb-s1&quot;&gt;Step 1 — Profile&lt;/span&gt;
      &lt;span aria-hidden=&quot;true&quot;&gt;25%&lt;/span&gt;
    &lt;/div&gt;
    &lt;progress value=&quot;25&quot; max=&quot;100&quot; aria-labelledby=&quot;pb-s1&quot;&gt;&lt;/progress&gt;
  &lt;/div&gt;

  &lt;div class=&quot;progress-bar&quot;&gt;
    &lt;div class=&quot;progress-bar__header&quot;&gt;
      &lt;span id=&quot;pb-s2&quot;&gt;Step 2 — Payment&lt;/span&gt;
      &lt;span aria-hidden=&quot;true&quot;&gt;60%&lt;/span&gt;
    &lt;/div&gt;
    &lt;progress value=&quot;60&quot; max=&quot;100&quot; aria-labelledby=&quot;pb-s2&quot;&gt;&lt;/progress&gt;
  &lt;/div&gt;

  &lt;div class=&quot;progress-bar&quot;&gt;
    &lt;div class=&quot;progress-bar__header&quot;&gt;
      &lt;span id=&quot;pb-s3&quot;&gt;Step 3 — Complete&lt;/span&gt;
      &lt;span aria-hidden=&quot;true&quot;&gt;100%&lt;/span&gt;
    &lt;/div&gt;
    &lt;progress value=&quot;100&quot; max=&quot;100&quot; aria-labelledby=&quot;pb-s3&quot;&gt;&lt;/progress&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre>
    </details>
  </section>

  <section>
    <h2 class="heading-l">Indeterminate</h2>
    <p>Omit the <code>value</code> attribute to render an indeterminate (animating) bar — useful while waiting for a duration-unknown operation.</p>
    
    <div class="padding-m margin-y-m background-neutral-50 border border-neutral-200">
<div class="progress-bar">
  <span id="pb-proc" style="font-size: var(--font-size-xs); color: var(--color-neutral-600)">Processing…</span>
  <progress aria-labelledby="pb-proc"></progress>
</div>
    </div>

    <details class="margin-y-s">
      <summary class="padding-s">Show code</summary>
      <pre class="padding-m background-neutral-900" style="overflow-x: auto;"><code>&lt;div class=&quot;progress-bar&quot;&gt;
  &lt;span id=&quot;pb-proc&quot; style=&quot;font-size: var(--font-size-xs); color: var(--color-neutral-600)&quot;&gt;Processing…&lt;/span&gt;
  &lt;progress aria-labelledby=&quot;pb-proc&quot;&gt;&lt;/progress&gt;
&lt;/div&gt;</code></pre>
    </details>
  </section>

  <section>
    <h2 class="heading-l">Compact with aria-label</h2>
    <p>For compact contexts where no visible label is needed, apply <code>class="progress-bar"</code> directly to the <code>&lt;progress&gt;</code> element and provide an <code>aria-label</code>.</p>
    
    <div class="padding-m margin-y-m background-neutral-50 border border-neutral-200">
<progress
  class="progress-bar"
  value="40"
  max="100"
  aria-label="Profile completion: 40%"
></progress>
    </div>

    <details class="margin-y-s">
      <summary class="padding-s">Show code</summary>
      <pre class="padding-m background-neutral-900" style="overflow-x: auto;"><code>&lt;progress
  class=&quot;progress-bar&quot;
  value=&quot;40&quot;
  max=&quot;100&quot;
  aria-label=&quot;Profile completion: 40%&quot;
&gt;&lt;/progress&gt;</code></pre>
    </details>
  </section>

  <section>
    <h2 class="heading-l">Custom colour</h2>
    <p>Override <code>--progress-bar-color</code> to use a status colour instead of the default brand colour.</p>
    
    <div class="padding-m margin-y-m background-neutral-50 border border-neutral-200">
<div class="progress-bar" style="--progress-bar-color: var(--color-status-ok)">
  <div class="progress-bar__header">
    <span id="pb-ok">Password strength</span>
    <span aria-hidden="true">Strong</span>
  </div>
  <progress value="90" max="100" aria-labelledby="pb-ok"></progress>
</div>
    </div>

    <details class="margin-y-s">
      <summary class="padding-s">Show code</summary>
      <pre class="padding-m background-neutral-900" style="overflow-x: auto;"><code>&lt;div class=&quot;progress-bar&quot; style=&quot;--progress-bar-color: var(--color-status-ok)&quot;&gt;
  &lt;div class=&quot;progress-bar__header&quot;&gt;
    &lt;span id=&quot;pb-ok&quot;&gt;Password strength&lt;/span&gt;
    &lt;span aria-hidden=&quot;true&quot;&gt;Strong&lt;/span&gt;
  &lt;/div&gt;
  &lt;progress value=&quot;90&quot; max=&quot;100&quot; aria-labelledby=&quot;pb-ok&quot;&gt;&lt;/progress&gt;
&lt;/div&gt;</code></pre>
    </details>
  </section>

  <section>
    <h2 class="heading-l">Tokens</h2>
    <table class="">
      <thead>
        <tr>
          <th>Token</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>--progress-bar-color</code></td>
          <td><code>var(--color-brand)</code></td>
          <td>Fill colour of the progress track.</td>
        </tr>
        <tr>
          <td><code>--progress-bar-track</code></td>
          <td><code>var(--color-neutral-200)</code></td>
          <td>Background (empty) colour of the track.</td>
        </tr>
        <tr>
          <td><code>--progress-bar-height</code></td>
          <td><code>var(--space-xs)</code></td>
          <td>Height of the progress track.</td>
        </tr>
        <tr>
          <td><code>--progress-bar-radius</code></td>
          <td><code>9999px</code></td>
          <td>Corner radius of the track and fill.</td>
        </tr>
      </tbody>
    </table>
  </section>

</article>
{% endblock %}
