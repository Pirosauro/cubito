{% layout "layouts/base.liquid" %}
{% block title %}Sidebar — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/layouts/">Layouts</a></li>
        <li aria-current="page">Sidebar</li>
      </ol>
    </nav>
    <h1>Sidebar</h1>
    <p class="text-m color-neutral-600">Places a fixed-width sidebar next to a flexible main content area, stacking them vertically when the viewport is too narrow — no media queries needed.</p>
  </header>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Basic</h2>
      <p>The first direct child is the sidebar; the second is the main content area. The sidebar has a target width of <code>20rem</code> and the content area grows to fill the rest.</p>

      <div class="">
        <div class="sidebar">
          <nav class="docs-demo-aside flow" style="--flow-space: var(--space-xxs);" aria-label="Demo navigation">
            <p class="heading-xs color-brand text-bold margin-0">Navigation</p>
            <ul class="flow margin-0 padding-0" role="list" style="--flow-space: var(--space-tiny); list-style: none;">
              <li><a href="#" class="padding-xxs text-s text-no-underline color-neutral-800 background-neutral-200 radius-s" aria-current="page">Dashboard</a></li>
              <li><a href="#" class="padding-xxs text-s text-no-underline color-neutral-800">Team</a></li>
              <li><a href="#" class="padding-xxs text-s text-no-underline color-neutral-800">Projects</a></li>
              <li><a href="#" class="padding-xxs text-s text-no-underline color-neutral-800">Reports</a></li>
              <li><a href="#" class="padding-xxs text-s text-no-underline color-neutral-800">Settings</a></li>
            </ul>
          </nav>

          <main class="docs-demo-main flow" style="--flow-space: var(--space-xs);">
            <h2 class="heading-s margin-0">Dashboard</h2>
            <p class="text-s color-neutral-600 margin-0">Main content area grows to fill available space. It will never be narrower than <code>--sidebar-content-min-width</code> (default 50%).</p>
          </main>
        </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;sidebar&quot;&gt;
    &lt;nav class=&quot;docs-demo-aside&quot; aria-label=&quot;Demo navigation&quot;&gt;…&lt;/nav&gt;
    &lt;main class=&quot;docs-demo-main&quot;&gt;…&lt;/main&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Reverse</h2>
      <p>Add <code>data-direction="reverse"</code> to move the sidebar to the right. The last child becomes the sidebar and the first child becomes the content area.</p>

      <div class="">
        <div class="sidebar" data-direction="reverse">
          <article class="docs-demo-main flow" style="--flow-space: var(--space-xs);">
            <h2 class="heading-s margin-0">Article title</h2>
            <p class="text-s color-neutral-600 margin-0">The main content area sits on the left when the sidebar is reversed. Useful for article layouts with a contextual aside.</p>
          </article>

          <aside class="docs-demo-aside flow" style="--flow-space: var(--space-xxs);">
            <p class="heading-xs color-brand text-bold margin-0">In this article</p>
            <ul class="flow margin-0 padding-0" role="list" style="--flow-space: var(--space-tiny); list-style: none;">
              <li><a href="#" class="text-s text-no-underline color-neutral-800">Introduction</a></li>
              <li><a href="#" class="text-s text-no-underline color-neutral-800">Getting started</a></li>
              <li><a href="#" class="text-s text-no-underline color-neutral-800">Configuration</a></li>
              <li><a href="#" class="text-s text-no-underline color-neutral-800">API reference</a></li>
            </ul>
          </aside>
        </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;sidebar&quot; data-direction=&quot;reverse&quot;&gt;
    &lt;article class=&quot;docs-demo-main&quot;&gt;…&lt;/article&gt;
    &lt;aside class=&quot;docs-demo-aside&quot;&gt;…&lt;/aside&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Sticky sidebar</h2>
      <p>Add <code>data-variant="sticky"</code> to make the sidebar sticky on viewports wider than 960 px. The sidebar scrolls with the page below that breakpoint.</p>

      <div class="">
        <div class="sidebar" data-variant="sticky">
          <nav class="docs-demo-aside flow" style="--flow-space: var(--space-xxs);">
            <p class="heading-xs color-brand text-bold margin-0">Docs</p>
            <ul class="flow margin-0 padding-0" role="list" style="--flow-space: var(--space-tiny); list-style: none;">
              <li><a href="#" class="text-s text-no-underline color-neutral-800">Overview</a></li>
              <li><a href="#" class="text-s text-no-underline color-neutral-800">Installation</a></li>
              <li><a href="#" class="text-s text-no-underline color-neutral-800">Configuration</a></li>
            </ul>
            <p class="text-xs color-brand margin-0">Sticky on ≥ 960 px</p>
          </nav>

          <main class="docs-demo-main">
            <p class="text-s color-neutral-600 margin-0">The sidebar stays in view while the content area scrolls on wide viewports. On narrow viewports they stack normally.</p>
          </main>
        </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;sidebar&quot; data-variant=&quot;sticky&quot;&gt;
    &lt;nav class=&quot;docs-demo-aside&quot;&gt;…&lt;/nav&gt;
    &lt;main class=&quot;docs-demo-main&quot;&gt;…&lt;/main&gt;
  &lt;/div&gt;</code></pre>
      </details>

      <div class="callout wide" data-variant="brand" role="note">
        <p><code>data-variant="sticky"</code> applies <code>position: sticky</code> to the first child on viewports wider than 960 px. The sticky sidebar is capped at <code>100vh</code> and scrolls internally if its content is taller than the viewport.</p>
      </div>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Tokens</h2>
      <table>
        <thead>
          <tr>
            <th>Token</th>
            <th>Default</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--sidebar-target-width</code></td>
            <td><code>20rem</code></td>
            <td>Target width of the sidebar.</td>
          </tr>
          <tr>
            <td><code>--sidebar-content-min-width</code></td>
            <td><code>50%</code></td>
            <td>Minimum width of the main content area before stacking.</td>
          </tr>
          <tr>
            <td><code>--sidebar-gutter</code></td>
            <td><code>var(--space-s-l)</code></td>
            <td>Gap between sidebar and content area.</td>
          </tr>
        </tbody>
      </table>
  
    </div>
  </section>

</article>
{% endblock %}
