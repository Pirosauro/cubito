{% layout "layouts/base.liquid" %}
{% block title %}Grid — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/layouts/">Layouts</a></li>
        <li aria-current="page">Grid</li>
      </ol>
    </nav>
    <h1>Grid</h1>
    <p class="text-m color-neutral-600">An auto-fill CSS grid whose columns collapse responsively without any media queries — each column is at least <code>--grid-min-item-size</code> wide and the grid fits as many as it can.</p>
  </header>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Auto-fill grid</h2>
      <p>By default the grid fills as many <code>16rem</code>-minimum columns as the container allows. Resize the window to see columns collapse.</p>
    
      <div class="">
  <div class="grid">
    <div class="docs-demo-chip docs-demo-chip--1">Item 1</div>
    <div class="docs-demo-chip docs-demo-chip--2">Item 2</div>
    <div class="docs-demo-chip docs-demo-chip--3">Item 3</div>
    <div class="docs-demo-chip docs-demo-chip--4">Item 4</div>
    <div class="docs-demo-chip docs-demo-chip--5">Item 5</div>
    <div class="docs-demo-chip docs-demo-chip--6">Item 6</div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;grid&quot;&gt;
    &lt;div class=&quot;docs-demo-chip docs-demo-chip--1&quot;&gt;Item 1&lt;/div&gt;
    …
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Fixed columns</h2>
      <p>Use <code>data-layout="50%"</code> for a two-column layout or <code>data-layout="33%"</code> for three columns. Both still collapse when the container is too narrow.</p>
    
      <div class="">
  <p class="text-s color-neutral-600 docs-caption">data-layout="50%" — two columns</p>
  <div class="grid" data-layout="50%">
    <div class="docs-demo-chip docs-demo-chip--1">Column A</div>
    <div class="docs-demo-chip docs-demo-chip--5">Column B</div>
  </div>

  <p class="text-s color-neutral-600 docs-caption margin-y-m">data-layout="33%" — three columns</p>
  <div class="grid" data-layout="33%">
    <div class="docs-demo-chip docs-demo-chip--1">Col A</div>
    <div class="docs-demo-chip docs-demo-chip--3">Col B</div>
    <div class="docs-demo-chip docs-demo-chip--5">Col C</div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;p style=&quot;class="text-s color-neutral-600 docs-caption";&quot;&gt;data-layout=&quot;50%&quot; — two columns&lt;/p&gt;
  &lt;div class=&quot;grid&quot; data-layout=&quot;50%&quot;&gt;
    &lt;div style=&quot;background: #e0e7ff; padding: 1.25rem; border-radius: 0.25rem; text-align: center;&quot;&gt;Column A&lt;/div&gt;
    &lt;div style=&quot;background: #6366f1; color: #fff; padding: 1.25rem; border-radius: 0.25rem; text-align: center;&quot;&gt;Column B&lt;/div&gt;
  &lt;/div&gt;

  &lt;p style=&quot;class="text-s color-neutral-600 docs-caption margin-y-m";&quot;&gt;data-layout=&quot;33%&quot; — three columns&lt;/p&gt;
  &lt;div class=&quot;grid&quot; data-layout=&quot;33%&quot;&gt;
    &lt;div style=&quot;background: #e0e7ff; padding: 1.25rem; border-radius: 0.25rem; text-align: center;&quot;&gt;Col A&lt;/div&gt;
    &lt;div style=&quot;background: #a5b4fc; padding: 1.25rem; border-radius: 0.25rem; text-align: center;&quot;&gt;Col B&lt;/div&gt;
    &lt;div style=&quot;background: #6366f1; color: #fff; padding: 1.25rem; border-radius: 0.25rem; text-align: center;&quot;&gt;Col C&lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Min item size</h2>
      <p>Override <code>--grid-min-item-size</code> to control when columns collapse. A smaller value keeps more columns at narrower widths; a larger value collapses earlier.</p>
    
      <div class="">
  <p class="text-s color-neutral-600 docs-caption">--grid-min-item-size: 8rem — fits more columns</p>
  <div class="grid" style="--grid-min-item-size: 8rem;">
    <div style="background: #e0e7ff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;">A</div>
    <div style="background: #c7d2fe; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;">B</div>
    <div style="background: #a5b4fc; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;">C</div>
    <div style="background: #818cf8; color: #fff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;">D</div>
    <div style="background: #6366f1; color: #fff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;">E</div>
    <div style="background: #4f46e5; color: #fff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;">F</div>
    <div style="background: #3730a3; color: #fff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;">G</div>
    <div style="background: #312e81; color: #fff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;">H</div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;p style=&quot;class="text-s color-neutral-600 docs-caption";&quot;&gt;--grid-min-item-size: 8rem — fits more columns&lt;/p&gt;
  &lt;div class=&quot;grid&quot; style=&quot;--grid-min-item-size: 8rem;&quot;&gt;
    &lt;div style=&quot;background: #e0e7ff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;&quot;&gt;A&lt;/div&gt;
    &lt;div style=&quot;background: #c7d2fe; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;&quot;&gt;B&lt;/div&gt;
    &lt;div style=&quot;background: #a5b4fc; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;&quot;&gt;C&lt;/div&gt;
    &lt;div style=&quot;background: #818cf8; color: #fff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;&quot;&gt;D&lt;/div&gt;
    &lt;div style=&quot;background: #6366f1; color: #fff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;&quot;&gt;E&lt;/div&gt;
    &lt;div style=&quot;background: #4f46e5; color: #fff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;&quot;&gt;F&lt;/div&gt;
    &lt;div style=&quot;background: #3730a3; color: #fff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;&quot;&gt;G&lt;/div&gt;
    &lt;div style=&quot;background: #312e81; color: #fff; padding: 1rem; border-radius: 0.25rem; text-align: center; font-size: 0.875rem;&quot;&gt;H&lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Tokens</h2>
      <table class="">
        <thead>
          <tr>
            <th>Token</th>
            <th>Default</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--grid-gutter</code></td>
            <td><code>var(--space-s-l)</code></td>
            <td>Gap between grid cells.</td>
          </tr>
          <tr>
            <td><code>--grid-min-item-size</code></td>
            <td><code>16rem</code></td>
            <td>Minimum column width. The grid creates as many columns as fit above this threshold.</td>
          </tr>
          <tr>
            <td><code>--grid-placement</code></td>
            <td><code>auto-fill</code></td>
            <td>Use <code>auto-fill</code> to keep empty tracks, or <code>auto-fit</code> to collapse them. The <code>data-layout</code> variants use <code>auto-fit</code>.</td>
          </tr>
        </tbody>
      </table>

      <h3 style="margin-block-start: var(--space-m)">Data attributes</h3>
      <table class="">
        <thead>
          <tr>
            <th>Attribute</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>data-layout="50%"</code></td>
            <td>Two equal columns that collapse when space is insufficient.</td>
          </tr>
          <tr>
            <td><code>data-layout="33%"</code></td>
            <td>Three equal columns that collapse when space is insufficient.</td>
          </tr>
          <tr>
            <td><code>data-rows="masonry"</code></td>
            <td>Enables CSS masonry row layout where supported; degrades to a normal grid.</td>
          </tr>
        </tbody>
      </table>
  
    </div>
  </section>

</article>
{% endblock %}
