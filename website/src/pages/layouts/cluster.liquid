{% layout "layouts/base.liquid" %}
{% block title %}Cluster — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/layouts/">Layouts</a></li>
        <li aria-current="page">Cluster</li>
      </ol>
    </nav>
    <h1>Cluster</h1>
    <p class="text-m color-neutral-600">Distributes items with consistent spacing, wrapping naturally when they run out of space — no media queries needed.</p>
  </header>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Basic</h2>
      <p>Items in a <code>.cluster</code> wrap to new lines automatically when the container is too narrow to fit them all on one row.</p>

      <div class="">
        <div class="cluster">
          <div style="width: 25%">Item one</div>
          <div style="width: 25%">Item two</div>
          <div style="width: 25%">Item three</div>
          <div style="width: 25%">Item four</div>
          <div style="width: 25%">Item five</div>
          <div style="width: 25%">Item six</div>
        </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;cluster&quot;&gt;
    &lt;div class=&quot;docs-demo-chip docs-demo-chip--1&quot;&gt;Item one&lt;/div&gt;
    &lt;div class=&quot;docs-demo-chip docs-demo-chip--2&quot;&gt;Item two&lt;/div&gt;
    &lt;div class=&quot;docs-demo-chip docs-demo-chip--3&quot;&gt;Item three&lt;/div&gt;
    &lt;div class=&quot;docs-demo-chip docs-demo-chip--4&quot;&gt;Item four&lt;/div&gt;
    &lt;div class=&quot;docs-demo-chip docs-demo-chip--5&quot;&gt;Item five&lt;/div&gt;
    &lt;div class=&quot;docs-demo-chip docs-demo-chip--6&quot;&gt;Item six&lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">With real content</h2>
      <p>A cluster is ideal for tag clouds, badge groups, and filter bars where items have variable widths.</p>

      <div class="">
        <div class="cluster" style="--gutter: var(--space-xxs);">
          <span class="badge">All</span>
          <span class="badge" data-variant="info">Design</span>
          <span class="badge" data-variant="success">Engineering</span>
          <span class="badge" data-variant="warning">Product</span>
          <span class="badge" data-variant="error">Leadership</span>
          <span class="badge">Strategy</span>
          <span class="badge" data-variant="info">Research</span>
        </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;cluster&quot; style=&quot;--gutter: var(--space-xxs);&quot;&gt;
    &lt;span class=&quot;badge&quot;&gt;All&lt;/span&gt;
    …
  &lt;/div&gt;</code></pre>
      </details>

      {% capture demo2 %}
  <div class="cluster">
    <button class="button" data-variant="outline">Reset filters</button>
    <button class="button" data-variant="outline">Price: low to high</button>
    <button class="button" data-variant="outline">In stock only</button>
    <button class="button" data-variant="outline">Free shipping</button>
    <button class="button">Apply</button>
  </div>
      {% endcapture %}
      {% include "partials/demo.liquid", html: demo2, title: "Filter bar using buttons" %}
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Alignment</h2>
      <p>Override <code>--cluster-horizontal-alignment</code> to control how items are distributed along the main axis.</p>

      <div class=" flow" style="--flow-space: var(--space-m);">
        <div>
          <p class="text-s color-neutral-600 docs-caption">center</p>
          <div class="cluster docs-demo-panel" style="--cluster-horizontal-alignment: center;">
            <div class="docs-demo-chip docs-demo-chip--1 padding-x-m">Alpha</div>
            <div class="docs-demo-chip docs-demo-chip--2 padding-x-m">Beta</div>
            <div class="docs-demo-chip docs-demo-chip--3 padding-x-m">Gamma</div>
          </div>
        </div>

        <div>
          <p class="text-s color-neutral-600 docs-caption">flex-end</p>
          <div class="cluster docs-demo-panel" style="--cluster-horizontal-alignment: flex-end;">
            <div class="docs-demo-chip docs-demo-chip--4 padding-x-m">Alpha</div>
            <div class="docs-demo-chip docs-demo-chip--5 padding-x-m">Beta</div>
            <div class="docs-demo-chip docs-demo-chip--6 padding-x-m">Gamma</div>
          </div>
        </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;cluster docs-demo-panel&quot; style=&quot;--cluster-horizontal-alignment: center;&quot;&gt;
    &lt;div class=&quot;docs-demo-chip docs-demo-chip--1&quot;&gt;Alpha&lt;/div&gt;
    …
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Tokens</h2>
      <table>
        <thead>
          <tr>
            <th>Token</th>
            <th>Default</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--gutter</code></td>
            <td><code>var(--space-s-l)</code></td>
            <td>Gap between items. Falls back to the global <code>--space-s-l</code> fluid spacing token.</td>
          </tr>
          <tr>
            <td><code>--cluster-horizontal-alignment</code></td>
            <td><code>flex-start</code></td>
            <td>Controls <code>justify-content</code>. Accepts any flex alignment value.</td>
          </tr>
          <tr>
            <td><code>--cluster-vertical-alignment</code></td>
            <td><code>center</code></td>
            <td>Controls <code>align-items</code>. Accepts any flex alignment value.</td>
          </tr>
        </tbody>
      </table>
  
    </div>
  </section>

</article>
{% endblock %}
