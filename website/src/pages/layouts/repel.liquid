{% layout "layouts/base.liquid" %}
{% block title %}Repel — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/layouts/">Layouts</a></li>
        <li aria-current="page">Repel</li>
      </ol>
    </nav>
    <h1>Repel</h1>
    <p class="text-m color-neutral-600">Pushes two groups of items to opposite ends of their container when space allows, and stacks them vertically on narrow viewports.</p>
  </header>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Basic</h2>
      <p>Place exactly two children inside <code>.repel</code>. The first is aligned to the start, the second to the end.</p>

      <div class="">
        <div class="repel docs-demo-panel">
          <h2 class="heading-s margin-0">Team members</h2>
          <button class="button">Add member</button>
        </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;repel docs-demo-panel&quot;&gt;
    &lt;h2 class=&quot;heading-s&quot;&gt;Team members&lt;/h2&gt;
    &lt;button class=&quot;button&quot;&gt;Add member&lt;/button&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">With real content</h2>
      <p>Repel works well for pagination toolbars where previous/next controls sit at opposite ends.</p>

      <div class="">
        <nav aria-label="Pagination" class="repel docs-demo-panel">
          <a href="#" class="button" data-variant="outline" rel="prev">← Previous</a>
          <span class="text-s color-neutral-600">Page 3 of 12</span>
          <a href="#" class="button" data-variant="outline" rel="next">Next →</a>
        </nav>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;nav class=&quot;repel docs-demo-panel&quot; aria-label=&quot;Pagination&quot;&gt;…&lt;/nav&gt;</code></pre>
      </details>

      {% capture demo2 %}
  <div class="repel docs-demo-panel">
    <div class="flow" style="--flow-space: var(--space-tiny);">
      <p class="text-bold margin-0">3 items selected</p>
      <p class="text-s color-neutral-600 margin-0">Select all 142 results</p>
    </div>
    <div class="cluster" style="--cluster-gutter: var(--space-xxs);">
      <button class="button" data-variant="outline">Export</button>
      <button class="button" data-variant="outline">Assign</button>
      <button class="button" data-variant="destructive">Delete</button>
    </div>
  </div>
      {% endcapture %}
      {% include "partials/demo.liquid", html: demo2, title: "Bulk-action toolbar" %}
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Nowrap</h2>
      <p>Add <code>data-nowrap</code> to prevent stacking. Use with caution — this can cause overflow on small screens.</p>

      <div class="">
        <div class="repel docs-demo-panel" data-nowrap>
          <span class="text-bold">Invoice #INV-2024-0091</span>
          <span class="badge" data-variant="warning">Pending review</span>
        </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;repel docs-demo-panel&quot; data-nowrap&gt;…&lt;/div&gt;</code></pre>
      </details>

      <div class="callout wide" data-variant="brand" role="note">
        <p><code>data-nowrap</code> sets <code>flex-wrap: nowrap</code>. Content that cannot fit will overflow unless truncation is applied to individual children.</p>
      </div>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Tokens</h2>
      <table>
        <thead>
          <tr>
            <th>Token</th>
            <th>Default</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>--repel-gutter</code></td>
            <td><code>var(--space-s-l)</code></td>
            <td>Gap between groups when stacked on narrow viewports.</td>
          </tr>
          <tr>
            <td><code>--repel-vertical-alignment</code></td>
            <td><code>center</code></td>
            <td>Controls <code>align-items</code>.</td>
          </tr>
        </tbody>
      </table>
  
    </div>
  </section>

</article>
{% endblock %}
