{% layout "layouts/base.liquid" %}
{% block title %}Nav — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/base/">Base Elements</a></li>
        <li aria-current="page">Nav</li>
      </ol>
    </nav>
    <h1>Nav</h1>
    <p class="text-m color-neutral-600">Navigation element styles with two variants — a horizontal top-bar (<code>data-variant="main"</code>) and a collapsible tree sidebar (<code>data-variant="sidebar"</code>).</p>
  </header>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Basic nav</h2>
      <p>A plain <code>&lt;nav&gt;</code> with no variant gives you a minimal list of links. Use <code>aria-current="page"</code> on the active link to signal the current location to assistive technology.</p>
    
      <div class="">
  <nav aria-label="Site sections">
    <ul role="list" style="display: flex; gap: var(--space-s); list-style: none; margin: 0; padding: 0">
      <li><a href="#">Home</a></li>
      <li><a href="#" aria-current="page">Products</a></li>
      <li><a href="#">Pricing</a></li>
      <li><a href="#">Blog</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
  </nav>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;nav aria-label=&quot;Site sections&quot;&gt;
    &lt;ul role=&quot;list&quot; style=&quot;display: flex; gap: var(--space-s); list-style: none; margin: 0; padding: 0&quot;&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Home&lt;/a&gt;&lt;/li&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot; aria-current=&quot;page&quot;&gt;Products&lt;/a&gt;&lt;/li&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Pricing&lt;/a&gt;&lt;/li&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Blog&lt;/a&gt;&lt;/li&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Contact&lt;/a&gt;&lt;/li&gt;
    &lt;/ul&gt;
  &lt;/nav&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Horizontal nav variant</h2>
      <p>Add <code>data-variant="horizontal"</code> to a <code>&lt;nav&gt;</code> for a top-level navigation bar rendered as a horizontal row. Active links use the default link active tokens. An optional <code>&lt;span&gt;</code> inside the link can hold an icon.</p>
    
      <div class="">
  <nav data-variant="horizontal" aria-label="Main navigation">
    <ul role="list" style="display: flex; gap: 0; list-style: none; margin: 0; padding: 0">
      <li>
        <a href="#">
          <span aria-hidden="true">
            <svg width="1em" height="1em" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6L8 1l6 5v8a1 1 0 01-1 1H3a1 1 0 01-1-1z"/><path d="M6 16V8h4v8"/></svg>
          </span>
          Home
        </a>
      </li>
      <li><a href="#">Products</a></li>
      <li><a href="#" aria-current="page">Pricing</a></li>
      <li><a href="#">Blog</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
  </nav>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;nav data-variant=&quot;main&quot; aria-label=&quot;Main navigation&quot;&gt;
    &lt;ul role=&quot;list&quot; style=&quot;display: flex; gap: 0; list-style: none; margin: 0; padding: 0&quot;&gt;
      &lt;li&gt;
        &lt;a href=&quot;#&quot;&gt;
          &lt;span aria-hidden=&quot;true&quot;&gt;
            &lt;svg width=&quot;1em&quot; height=&quot;1em&quot; viewBox=&quot;0 0 16 16&quot; fill=&quot;none&quot; stroke=&quot;currentColor&quot; stroke-width=&quot;1.5&quot; stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot;&gt;&lt;path d=&quot;M2 6L8 1l6 5v8a1 1 0 01-1 1H3a1 1 0 01-1-1z&quot;/&gt;&lt;path d=&quot;M6 16V8h4v8&quot;/&gt;&lt;/svg&gt;
          &lt;/span&gt;
          Home
        &lt;/a&gt;
      &lt;/li&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Products&lt;/a&gt;&lt;/li&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot; aria-current=&quot;page&quot;&gt;Pricing&lt;/a&gt;&lt;/li&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Blog&lt;/a&gt;&lt;/li&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Contact&lt;/a&gt;&lt;/li&gt;
    &lt;/ul&gt;
  &lt;/nav&gt;</code></pre>
      </details>

      <table class="">
        <thead><tr><th>Token</th><th>Default</th><th>Description</th></tr></thead>
        <tbody>
          <tr><td><code>--nav-horizontal-gap</code></td><td><code>var(--nav-default-gap)</code></td><td>Gap between links in the horizontal row.</td></tr>
          <tr><td><code>--nav-horizontal-padding</code></td><td><code>var(--nav-default-padding)</code></td><td>Padding around each link.</td></tr>
        </tbody>
      </table>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Sidebar nav variant</h2>
      <p>Add <code>data-variant="sidebar"</code> for a tree-style navigation. Nested sub-lists are hidden by default; toggling <code>data-state="active"</code> on a parent <code>&lt;li&gt;</code> or adding <code>data-state="visible"</code> on the <code>&lt;ul&gt;</code> reveals them. Items that have children should also carry <code>data-children="true"</code> to render the animated chevron indicator.</p>
    
      <div class="">
  <nav data-variant="sidebar" aria-label="Documentation navigation" style="max-width: 16rem; border: 1px solid var(--color-neutral-200); border-radius: var(--border-radius-m); overflow: hidden">
    <ul role="list" style="list-style: none; margin: 0; padding: var(--space-xxs) 0">
      <li><a href="#">Getting started</a></li>
      <li data-children="true" data-state="active">
        <a href="#" aria-current="page">Base Elements</a>
        <ul data-state="visible" role="list" style="list-style: none; margin: 0; padding: 0">
          <li><a href="#">Button</a></li>
          <li><a href="#">Form</a></li>
          <li><a href="#">Table</a></li>
          <li><a href="#" aria-current="page">Nav</a></li>
        </ul>
      </li>
      <li data-children="true">
        <a href="#">Components</a>
        <ul role="list" style="list-style: none; margin: 0; padding: 0; display: none">
          <li><a href="#">Badge</a></li>
          <li><a href="#">Card</a></li>
          <li><a href="#">Dialog</a></li>
        </ul>
      </li>
      <li><a href="#">Utilities</a></li>
      <li><a href="#">Changelog</a></li>
    </ul>
  </nav>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;nav data-variant=&quot;sidebar&quot; aria-label=&quot;Documentation navigation&quot; style=&quot;max-width: 16rem; border: 1px solid var(--color-neutral-200); border-radius: var(--border-radius-m); overflow: hidden&quot;&gt;
    &lt;ul role=&quot;list&quot; style=&quot;list-style: none; margin: 0; padding: var(--space-xxs) 0&quot;&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Getting started&lt;/a&gt;&lt;/li&gt;
      &lt;li data-children=&quot;true&quot; data-state=&quot;active&quot;&gt;
        &lt;a href=&quot;#&quot; aria-current=&quot;page&quot;&gt;Base Elements&lt;/a&gt;
        &lt;ul data-state=&quot;visible&quot; role=&quot;list&quot; style=&quot;list-style: none; margin: 0; padding: 0&quot;&gt;
          &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Button&lt;/a&gt;&lt;/li&gt;
          &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Form&lt;/a&gt;&lt;/li&gt;
          &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Table&lt;/a&gt;&lt;/li&gt;
          &lt;li&gt;&lt;a href=&quot;#&quot; aria-current=&quot;page&quot;&gt;Nav&lt;/a&gt;&lt;/li&gt;
        &lt;/ul&gt;
      &lt;/li&gt;
      &lt;li data-children=&quot;true&quot;&gt;
        &lt;a href=&quot;#&quot;&gt;Components&lt;/a&gt;
        &lt;ul role=&quot;list&quot; style=&quot;list-style: none; margin: 0; padding: 0; display: none&quot;&gt;
          &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Badge&lt;/a&gt;&lt;/li&gt;
          &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Card&lt;/a&gt;&lt;/li&gt;
          &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Dialog&lt;/a&gt;&lt;/li&gt;
        &lt;/ul&gt;
      &lt;/li&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Utilities&lt;/a&gt;&lt;/li&gt;
      &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Changelog&lt;/a&gt;&lt;/li&gt;
    &lt;/ul&gt;
  &lt;/nav&gt;</code></pre>
      </details>

      <table class="">
        <thead><tr><th>Token</th><th>Default</th><th>Description</th></tr></thead>
        <tbody>
          <tr><td><code>--nav-sidebar-gap</code></td><td><code>var(--nav-default-gap)</code></td><td>Gap between list items.</td></tr>
          <tr><td><code>--nav-sidebar-padding</code></td><td><code>var(--space-tiny) var(--space-s)</code></td><td>Padding around each link.</td></tr>
          <tr><td><code>--nav-sidebar-nested-padding</code></td><td><code>var(--space-s)</code></td><td>Inline padding applied to nested sub-lists.</td></tr>
          <tr><td><code>--nav-sidebar-chevron-size</code></td><td><code>1.25rem</code></td><td>Size of the expand/collapse chevron indicator.</td></tr>
          <tr><td><code>--nav-sidebar-chevron-color</code></td><td><code>currentColor</code></td><td>Colour of the chevron indicator.</td></tr>
        </tbody>
      </table>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Active state</h2>
      <p>The preferred way to mark an active link is <code>aria-current="page"</code> — it is semantic and picked up by screen readers. The <code>data-state="active"</code> attribute exists for JS-driven trees where <code>aria-expanded</code> is already in use on the parent element.</p>
    
      <div class="">
  <div class="flow">
    <p>Using <code>aria-current="page"</code> (preferred):</p>
    <nav data-variant="main" aria-label="Example A">
      <ul role="list" style="display: flex; gap: 0; list-style: none; margin: 0; padding: 0">
        <li><a href="#">Overview</a></li>
        <li><a href="#" aria-current="page">Settings</a></li>
        <li><a href="#">Help</a></li>
      </ul>
    </nav>

    <p>Using <code>data-state="active"</code> (JS-driven):</p>
    <nav data-variant="main" aria-label="Example B">
      <ul role="list" style="display: flex; gap: 0; list-style: none; margin: 0; padding: 0">
        <li><a href="#">Overview</a></li>
        <li><a href="#" data-state="active">Settings</a></li>
        <li><a href="#">Help</a></li>
      </ul>
    </nav>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;flow&quot;&gt;
    &lt;p&gt;Using &lt;code&gt;aria-current=&quot;page&quot;&lt;/code&gt; (preferred):&lt;/p&gt;
    &lt;nav data-variant=&quot;main&quot; aria-label=&quot;Example A&quot;&gt;
      &lt;ul role=&quot;list&quot; style=&quot;display: flex; gap: 0; list-style: none; margin: 0; padding: 0&quot;&gt;
        &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Overview&lt;/a&gt;&lt;/li&gt;
        &lt;li&gt;&lt;a href=&quot;#&quot; aria-current=&quot;page&quot;&gt;Settings&lt;/a&gt;&lt;/li&gt;
        &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Help&lt;/a&gt;&lt;/li&gt;
      &lt;/ul&gt;
    &lt;/nav&gt;

    &lt;p&gt;Using &lt;code&gt;data-state=&quot;active&quot;&lt;/code&gt; (JS-driven):&lt;/p&gt;
    &lt;nav data-variant=&quot;main&quot; aria-label=&quot;Example B&quot;&gt;
      &lt;ul role=&quot;list&quot; style=&quot;display: flex; gap: 0; list-style: none; margin: 0; padding: 0&quot;&gt;
        &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Overview&lt;/a&gt;&lt;/li&gt;
        &lt;li&gt;&lt;a href=&quot;#&quot; data-state=&quot;active&quot;&gt;Settings&lt;/a&gt;&lt;/li&gt;
        &lt;li&gt;&lt;a href=&quot;#&quot;&gt;Help&lt;/a&gt;&lt;/li&gt;
      &lt;/ul&gt;
    &lt;/nav&gt;
  &lt;/div&gt;</code></pre>
      </details>
      <div class="callout wide" data-variant="brand" role="note"><p>Both <code>aria-current="page"</code> and <code>data-state="active"</code> apply the same visual treatment. Prefer <code>aria-current</code> for page-level navigation; use <code>data-state</code> only when <code>aria-current</code> is already occupied by another ARIA pattern on the same element.</p></div>
  
    </div>
  </section>

</article>
{% endblock %}
