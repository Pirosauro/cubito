      <tr>
        <td>web-prod-02</td><td>eu-west-1</td><td>9%</td><td>3.8 GB</td><td>120 GB</td><td>47d 3h</td><td>Healthy</td>
      </tr>
      <tr>
        <td>db-primary</td><td>eu-west-1</td><td>34%</td><td>14.1 GB</td><td>500 GB</td><td>120d 7h</td><td>Healthy</td>
      </tr>
    </tbody>
  </table>
</div>
    </div>

