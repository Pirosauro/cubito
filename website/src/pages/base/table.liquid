  <section>
    <h2 class="heading-l">Variants</h2>
    <p>Three <code>data-variant</code> values change cell borders and padding.</p>

    
    <div class="padding-m margin-y-m background-neutral-50 border border-neutral-200">
<div class="flow">
  <p><strong>Borderless</strong> — no cell borders at all:</p>
  <div class="table-wrapper">
    <table data-variant="borderless">
      <thead><tr><th scope="col">Region</th><th scope="col">Q1</th><th scope="col">Q2</th><th scope="col">YTD</th></tr></thead>
      <tbody>
        <tr><td>EMEA</td><td>£1.2m</td><td>£1.5m</td><td>£2.7m</td></tr>
        <tr><td>APAC</td><td>£0.9m</td><td>£1.1m</td><td>£2.0m</td></tr>
        <tr><td>Americas</td><td>£2.4m</td><td>£2.8m</td><td>£5.2m</td></tr>
      </tbody>
    </table>
  </div>

  <p><strong>Lined</strong> — horizontal rules only:</p>
  <div class="table-wrapper">
    <table data-variant="lined">
      <thead><tr><th scope="col">Region</th><th scope="col">Q1</th><th scope="col">Q2</th><th scope="col">YTD</th></tr></thead>
      <tbody>
        <tr><td>EMEA</td><td>£1.2m</td><td>£1.5m</td><td>£2.7m</td></tr>
        <tr><td>APAC</td><td>£0.9m</td><td>£1.1m</td><td>£2.0m</td></tr>
        <tr><td>Americas</td><td>£2.4m</td><td>£2.8m</td><td>£5.2m</td></tr>
      </tbody>
    </table>
  </div>

  <p><strong>Compact</strong> — reduced padding and smaller font size for dense data:</p>
  <div class="table-wrapper">
    <table data-variant="compact">
      <thead><tr><th scope="col">Region</th><th scope="col">Q1</th><th scope="col">Q2</th><th scope="col">YTD</th></tr></thead>
      <tbody>
        <tr><td>EMEA</td><td>£1.2m</td><td>£1.5m</td><td>£2.7m</td></tr>
        <tr><td>APAC</td><td>£0.9m</td><td>£1.1m</td><td>£2.0m</td></tr>
        <tr><td>Americas</td><td>£2.4m</td><td>£2.8m</td><td>£5.2m</td></tr>
      </tbody>
    </table>
  </div>
</div>
    </div>

    <details class="margin-y-s">
      <summary class="padding-s">Show code</summary>
      <pre class="padding-m background-neutral-900" style="overflow-x: auto;"><code>&lt;div class=&quot;flow&quot;&gt;
