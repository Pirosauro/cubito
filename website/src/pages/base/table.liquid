  <section>
    <h2 class="heading-l">Tokens</h2>

    <table class="">
      <thead><tr><th>Token</th><th>Default</th><th>Description</th></tr></thead>
      <tbody>
        <tr><td colspan="3"><strong>Rows</strong></td></tr>
        <tr><td><code>--tr-background-odd</code></td><td><code>transparent</code></td><td>Background for odd rows (1st, 3rd, …).</td></tr>
        <tr><td><code>--tr-background-even</code></td><td><code>transparent</code></td><td>Background for even rows (2nd, 4th, …).</td></tr>
        <tr><td><code>--tr-color-odd</code></td><td><code>inherit</code></td><td>Text colour for odd rows.</td></tr>
        <tr><td><code>--tr-color-even</code></td><td><code>inherit</code></td><td>Text colour for even rows.</td></tr>
        <tr><td><code>--tr-background-odd-hover</code></td><td><code>var(--tr-background-odd)</code></td><td>Hover background for odd rows.</td></tr>
        <tr><td><code>--tr-background-even-hover</code></td><td><code>var(--tr-background-even)</code></td><td>Hover background for even rows.</td></tr>
        <tr><td colspan="3"><strong>Cells</strong></td></tr>
        <tr><td><code>--td-border-color</code></td><td><code>var(--color)</code></td><td>Cell border colour.</td></tr>
        <tr><td><code>--td-border-width</code></td><td><code>var(--border-s)</code></td><td>Cell border width.</td></tr>
        <tr><td><code>--td-border-style</code></td><td><code>solid</code></td><td>Cell border style.</td></tr>
        <tr><td><code>--td-padding</code></td><td><code>var(--space-tiny) var(--space-xxs)</code></td><td>Cell padding.</td></tr>
        <tr><td><code>--td-compact-padding</code></td><td><code>var(--space-xxs) var(--space-tiny)</code></td><td>Cell padding in compact variant.</td></tr>
        <tr><td><code>--td-compact-font-size</code></td><td><code>var(--font-size-xs)</code></td><td>Font size in compact variant.</td></tr>
        <tr><td colspan="3"><strong>Header</strong></td></tr>
        <tr><td><code>--th-background</code></td><td><code>var(--color)</code></td><td>Header cell background.</td></tr>
        <tr><td><code>--th-color</code></td><td><code>var(--background)</code></td><td>Header cell text colour.</td></tr>
