      &lt;thead&gt;&lt;tr&gt;&lt;th scope=&quot;col&quot;&gt;Region&lt;/th&gt;&lt;th scope=&quot;col&quot;&gt;Q1&lt;/th&gt;&lt;th scope=&quot;col&quot;&gt;Q2&lt;/th&gt;&lt;th scope=&quot;col&quot;&gt;YTD&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;
      &lt;tbody&gt;
        &lt;tr&gt;&lt;td&gt;EMEA&lt;/td&gt;&lt;td&gt;£1.2m&lt;/td&gt;&lt;td&gt;£1.5m&lt;/td&gt;&lt;td&gt;£2.7m&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;td&gt;APAC&lt;/td&gt;&lt;td&gt;£0.9m&lt;/td&gt;&lt;td&gt;£1.1m&lt;/td&gt;&lt;td&gt;£2.0m&lt;/td&gt;&lt;/tr&gt;
        &lt;tr&gt;&lt;td&gt;Americas&lt;/td&gt;&lt;td&gt;£2.4m&lt;/td&gt;&lt;td&gt;£2.8m&lt;/td&gt;&lt;td&gt;£5.2m&lt;/td&gt;&lt;/tr&gt;
      &lt;/tbody&gt;
    &lt;/table&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre>
    </details>

    <table class="">
      <thead><tr><th>Value</th><th>Description</th></tr></thead>
      <tbody>
        <tr><td><code>data-variant="borderless"</code></td><td>Removes all cell borders.</td></tr>
        <tr><td><code>data-variant="lined"</code></td><td>Horizontal rules only — bottom border per cell.</td></tr>
        <tr><td><code>data-variant="compact"</code></td><td>Reduced padding (<code>--td-compact-padding</code>) and smaller font (<code>--td-compact-font-size</code>).</td></tr>
        <tr><td><code>data-sticky-header</code></td><td>Makes <code>&lt;th&gt;</code> cells sticky at the top of the scroll container. Add to the <code>&lt;table&gt;</code> element.</td></tr>
      </tbody>
    </table>
  </section>

  <section>
