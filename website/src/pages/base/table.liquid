        <th scope="col">CPU</th>
        <th scope="col">Memory</th>
        <th scope="col">Disk</th>
        <th scope="col">Uptime</th>
        <th scope="col">Status</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>web-prod-01</td><td>eu-west-1</td><td>12%</td><td>4.2 GB</td><td>120 GB</td><td>47d 3h</td><td>Healthy</td>
