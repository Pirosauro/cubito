{% layout "layouts/base.liquid" %}
{% block title %}Z-Index — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/tokens/z-index/">Tokens</a></li>
        <li aria-current="page">Z-Index</li>
      </ol>
    </nav>
    <h1>Z-Index</h1>
    <p class="text-m color-neutral-600">A named z-index scale that replaces magic numbers with semantic layer names — ensuring every stacking context in the UI has a predictable, auditable position.</p>
  </header>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Stacking context table</h2>
      <p>Nine layers from document flow (<code>--z-base: 0</code>) to toast notifications (<code>--z-notification: 80</code>). Always use these tokens in components — never hardcode z-index integers.</p>

      <table class="">
        <thead>
          <tr><th>Layer name</th><th>Token</th><th>Value</th><th>Description</th></tr>
        </thead>
        <tbody>
          <tr>
            <td>base</td>
            <td><code>--z-base</code></td>
            <td><code>0</code></td>
            <td>Default document flow — no explicit stacking</td>
          </tr>
          <tr>
            <td>dropdown</td>
            <td><code>--z-dropdown</code></td>
            <td><code>10</code></td>
            <td>Inline select menus, comboboxes, autocomplete lists</td>
          </tr>
          <tr>
            <td>sticky</td>
            <td><code>--z-sticky</code></td>
            <td><code>20</code></td>
            <td>Sticky headers, sticky sidebars, in-page anchored elements</td>
          </tr>
          <tr>
            <td>fixed</td>
            <td><code>--z-fixed</code></td>
            <td><code>30</code></td>
            <td>Fixed navigation bars, persistent toolbars</td>
          </tr>
          <tr>
            <td>modal-backdrop</td>
            <td><code>--z-modal-backdrop</code></td>
            <td><code>50</code></td>
            <td>Semi-transparent overlay behind modal dialogs</td>
          </tr>
          <tr>
            <td>modal</td>
            <td><code>--z-modal</code></td>
            <td><code>51</code></td>
            <td>Modal dialogs and drawer panels</td>
          </tr>
          <tr>
            <td>popover</td>
            <td><code>--z-popover</code></td>
            <td><code>60</code></td>
            <td>Anchored floating panels — date pickers, color pickers, rich tooltips</td>
          </tr>
          <tr>
            <td>tooltip</td>
            <td><code>--z-tooltip</code></td>
            <td><code>70</code></td>
            <td>Simple instructional tooltips — always visible above all other UI</td>
          </tr>
          <tr>
            <td>notification</td>
            <td><code>--z-notification</code></td>
            <td><code>80</code></td>
            <td>Toast and snackbar messages — highest priority overlay</td>
          </tr>
        </tbody>
      </table>
  
    </div>
  </section>

