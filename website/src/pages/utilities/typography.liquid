{% layout "layouts/base.liquid" %}
{% block title %}Typography — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/utilities/">Utilities</a></li>
        <li aria-current="page">Typography</li>
      </ol>
    </nav>
    <h1>Typography</h1>
    <p class="text-m color-neutral-600">Convenience classes for applying type-scale tokens directly in markup. Heading utilities apply bold weight and tight leading; text utilities apply normal weight and base leading.</p>
  </header>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Heading sizes</h2>
      <p><code>.heading-{size}</code> classes apply the heading font family, bold weight, negative letter-spacing, and tight line-height — regardless of which HTML element they are placed on.</p>
    
      <div class="">
  <div class="flow" style="--flow-space: var(--space-s)">
    <p class="heading-huge">heading-huge</p>
    <p class="heading-xxl">heading-xxl</p>
    <p class="heading-xl">heading-xl</p>
    <p class="heading-l">heading-l</p>
    <p class="heading-m">heading-m</p>
    <p class="heading-s">heading-s</p>
    <p class="heading-xs">heading-xs</p>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;flow&quot; style=&quot;--flow-space: var(--space-s)&quot;&gt;
    &lt;p class=&quot;heading-huge&quot;&gt;heading-huge&lt;/p&gt;
    &lt;p class=&quot;heading-xxl&quot;&gt;heading-xxl&lt;/p&gt;
    &lt;p class=&quot;heading-xl&quot;&gt;heading-xl&lt;/p&gt;
    &lt;p class=&quot;heading-l&quot;&gt;heading-l&lt;/p&gt;
    &lt;p class=&quot;heading-m&quot;&gt;heading-m&lt;/p&gt;
    &lt;p class=&quot;heading-s&quot;&gt;heading-s&lt;/p&gt;
    &lt;p class=&quot;heading-xs&quot;&gt;heading-xs&lt;/p&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Text sizes</h2>
      <p><code>.text-{size}</code> classes apply the body font family, normal weight, and base line-height.</p>
    
      <div class="">
  <div class="flow" style="--flow-space: var(--space-xs)">
    <p class="text-huge">text-huge — display body</p>
    <p class="text-xxl">text-xxl</p>
    <p class="text-xl">text-xl</p>
    <p class="text-l">text-l</p>
    <p class="text-m">text-m — base size</p>
    <p class="text-s">text-s</p>
    <p class="text-xs">text-xs — captions and labels</p>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;flow&quot; style=&quot;--flow-space: var(--space-xs)&quot;&gt;
    &lt;p class=&quot;text-huge&quot;&gt;text-huge — display body&lt;/p&gt;
    &lt;p class=&quot;text-xxl&quot;&gt;text-xxl&lt;/p&gt;
    &lt;p class=&quot;text-xl&quot;&gt;text-xl&lt;/p&gt;
    &lt;p class=&quot;text-l&quot;&gt;text-l&lt;/p&gt;
    &lt;p class=&quot;text-m&quot;&gt;text-m — base size&lt;/p&gt;
    &lt;p class=&quot;text-s&quot;&gt;text-s&lt;/p&gt;
    &lt;p class=&quot;text-xs&quot;&gt;text-xs — captions and labels&lt;/p&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Weight</h2>
      <p><code>.text-bold</code> and <code>.text-normal</code> override the font weight without changing size or family.</p>
    
      <div class="">
  <div class="flow" style="--flow-space: var(--space-xs)">
    <p class="text-normal">Normal weight — the body default.</p>
    <p class="text-bold">Bold weight — strong emphasis.</p>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;flow&quot; style=&quot;--flow-space: var(--space-xs)&quot;&gt;
    &lt;p class=&quot;text-normal&quot;&gt;Normal weight — the body default.&lt;/p&gt;
    &lt;p class=&quot;text-bold&quot;&gt;Bold weight — strong emphasis.&lt;/p&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Alignment</h2>
      <p><code>.text-start</code>, <code>.text-center</code>, and <code>.text-end</code> map to logical alignment values that respect writing direction.</p>
    
      <div class="">
  <div class="flow" style="--flow-space: var(--space-xs)">
    <p class="text-start" style="background: var(--color-neutral-50); padding: var(--space-xs); border-radius: var(--border-radius-m)">.text-start (default)</p>
    <p class="text-center" style="background: var(--color-neutral-50); padding: var(--space-xs); border-radius: var(--border-radius-m)">.text-center</p>
    <p class="text-end" style="background: var(--color-neutral-50); padding: var(--space-xs); border-radius: var(--border-radius-m)">.text-end</p>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;flow&quot; style=&quot;--flow-space: var(--space-xs)&quot;&gt;
    &lt;p class=&quot;text-start&quot; style=&quot;background: var(--color-neutral-50); padding: var(--space-xs); border-radius: var(--border-radius-m)&quot;&gt;.text-start (default)&lt;/p&gt;
    &lt;p class=&quot;text-center&quot; style=&quot;background: var(--color-neutral-50); padding: var(--space-xs); border-radius: var(--border-radius-m)&quot;&gt;.text-center&lt;/p&gt;
    &lt;p class=&quot;text-end&quot; style=&quot;background: var(--color-neutral-50); padding: var(--space-xs); border-radius: var(--border-radius-m)&quot;&gt;.text-end&lt;/p&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Wrapping</h2>
      <p><code>.text-balance</code> distributes line lengths more evenly — ideal for headings. <code>.text-pretty</code> prevents orphaned single words on the last line of a paragraph.</p>
    
      <div class="">
  <div style="max-width: 30rem; display: grid; gap: var(--space-m)">
    <div>
      <p style="font-size: var(--font-size-xs); color: var(--color-neutral-500); margin-block-end: var(--space-xxs)">Without .text-balance</p>
      <h3 class="heading-m">The quick brown fox jumps over the lazy dog near the river</h3>
    </div>
    <div>
      <p style="font-size: var(--font-size-xs); color: var(--color-neutral-500); margin-block-end: var(--space-xxs)">With .text-balance</p>
      <h3 class="heading-m text-balance">The quick brown fox jumps over the lazy dog near the river</h3>
    </div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div style=&quot;max-width: 30rem; display: grid; gap: var(--space-m)&quot;&gt;
    &lt;div&gt;
      &lt;p style=&quot;font-size: var(--font-size-xs); color: var(--color-neutral-500); margin-block-end: var(--space-xxs)&quot;&gt;Without .text-balance&lt;/p&gt;
      &lt;h3 class=&quot;heading-m&quot;&gt;The quick brown fox jumps over the lazy dog near the river&lt;/h3&gt;
    &lt;/div&gt;
    &lt;div&gt;
      &lt;p style=&quot;font-size: var(--font-size-xs); color: var(--color-neutral-500); margin-block-end: var(--space-xxs)&quot;&gt;With .text-balance&lt;/p&gt;
      &lt;h3 class=&quot;heading-m text-balance&quot;&gt;The quick brown fox jumps over the lazy dog near the river&lt;/h3&gt;
    &lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Truncate</h2>
      <p><code>.text-truncate</code> clips text to a single line with an ellipsis. The element must have an explicit or constrained width.</p>
    
      <div class="">
  <p class="text-truncate" style="max-width: 20rem; background: var(--color-neutral-50); padding: var(--space-xs) var(--space-s); border-radius: var(--border-radius-m)">
    This is a very long piece of text that will be clipped with an ellipsis when it overflows its container.
  </p>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;p class=&quot;text-truncate&quot; style=&quot;max-width: 20rem; background: var(--color-neutral-50); padding: var(--space-xs) var(--space-s); border-radius: var(--border-radius-m)&quot;&gt;
    This is a very long piece of text that will be clipped with an ellipsis when it overflows its container.
  &lt;/p&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Monospace</h2>
      <p><code>.text-mono</code> switches to the monospace font family — useful for code snippets, version numbers, or tabular data outside a code element.</p>
    
      <div class="">
  <p class="text-mono text-s">v2.14.0 — released 2026-05-29</p>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;p class=&quot;text-mono text-s&quot;&gt;v2.14.0 — released 2026-05-29&lt;/p&gt;</code></pre>
      </details>
  
    </div>
  </section>

</article>
{% endblock %}
