{% layout "layouts/base.liquid" %}
{% block title %}Animation — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/utilities/">Utilities</a></li>
        <li aria-current="page">Animation</li>
      </ol>
    </nav>
    <h1>Animation</h1>
    <p class="text-m color-neutral-600">Utility classes for common, reusable CSS animations. All durations reference motion tokens that automatically collapse to <code>0ms</code> when <code>prefers-reduced-motion</code> is set.</p>
  </header>

  <div class="callout wide" data-variant="brand" role="note">
    <p>These utilities depend on the <code>--motion-duration-*</code> and <code>--motion-easing-*</code> tokens. When the user has requested reduced motion, those tokens resolve to <code>0ms</code>, making all animations effectively instant and invisible.</p>
  </div>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">blink</h2>
      <p>Cycles opacity between full and ~40% — useful for status indicators, live dots, or cursor simulations.</p>
    
      <div class="">
  <div style="display: flex; align-items: center; gap: var(--space-xs); font-size: var(--font-size-s)">
    <span class="blink" style="display: inline-block; width: 0.625rem; height: 0.625rem; background: var(--color-status-ok); border-radius: 50%;"></span>
    Live
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div style=&quot;display: flex; align-items: center; gap: var(--space-xs); font-size: var(--font-size-s)&quot;&gt;
    &lt;span class=&quot;blink&quot; style=&quot;display: inline-block; width: 0.625rem; height: 0.625rem; background: var(--color-status-ok); border-radius: 50%;&quot;&gt;&lt;/span&gt;
    Live
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">pulse</h2>
      <p>Gently scales the element up and back — draws attention without displacement.</p>
    
      <div class="">
  <span class="badge pulse" data-variant="error" style="display: inline-flex">3 alerts</span>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;span class=&quot;badge pulse&quot; data-variant=&quot;error&quot; style=&quot;display: inline-flex&quot;&gt;3 alerts&lt;/span&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">fade-in</h2>
      <p>Animates opacity from 0 to 1. Apply on mount when injecting content into the DOM.</p>
    
      <div class="">
  <p class="fade-in" style="background: var(--color-neutral-50); padding: var(--space-s); border-radius: var(--border-radius-m)">
    This paragraph fades in when the page loads.
  </p>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;p class=&quot;fade-in&quot; style=&quot;background: var(--color-neutral-50); padding: var(--space-s); border-radius: var(--border-radius-m)&quot;&gt;
    This paragraph fades in when the page loads.
  &lt;/p&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">slide-up</h2>
      <p>Combines a small upward translation with a fade — a natural enter animation for cards, panels, and dialogs.</p>
    
      <div class="">
  <div class="card slide-up" style="max-width: 24rem">
    <div style="padding: var(--space-m)">
      <h3 class="heading-s">Welcome back</h3>
      <p style="margin-block-start: var(--space-xs)">Your dashboard is ready.</p>
    </div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;card slide-up&quot; style=&quot;max-width: 24rem&quot;&gt;
    &lt;div style=&quot;padding: var(--space-m)&quot;&gt;
      &lt;h3 class=&quot;heading-s&quot;&gt;Welcome back&lt;/h3&gt;
      &lt;p style=&quot;margin-block-start: var(--space-xs)&quot;&gt;Your dashboard is ready.&lt;/p&gt;
    &lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

</article>
{% endblock %}
