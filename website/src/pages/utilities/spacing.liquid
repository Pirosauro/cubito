{% layout "layouts/base.liquid" %}
{% block title %}Spacing — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/utilities/">Utilities</a></li>
        <li aria-current="page">Spacing</li>
      </ol>
    </nav>
    <h1>Spacing</h1>
    <p class="text-m color-neutral-600">Padding and margin utilities built on the fluid <code>--space-*</code> scale. All values are responsive — each token is a <code>clamp()</code> expression that grows between 320px and 1240px viewport width.</p>
  </header>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Padding scale</h2>
      <p>Use <code>.padding-{size}</code> to apply padding on all four sides. The scale runs from <code>tiny</code> through <code>huge</code>.</p>
    
      <div class="">
  <div class="flow" style="--flow-space: var(--space-xs)">
    <div class="padding-tiny border border-neutral-300 radius" style="background: var(--color-neutral-50)">.padding-tiny</div>
    <div class="padding-xxs border border-neutral-300 radius" style="background: var(--color-neutral-50)">.padding-xxs</div>
    <div class="padding-xs border border-neutral-300 radius" style="background: var(--color-neutral-50)">.padding-xs</div>
    <div class="padding-s border border-neutral-300 radius" style="background: var(--color-neutral-50)">.padding-s</div>
    <div class="padding-m border border-neutral-300 radius" style="background: var(--color-neutral-50)">.padding-m</div>
    <div class="padding-l border border-neutral-300 radius" style="background: var(--color-neutral-50)">.padding-l</div>
    <div class="padding-xl border border-neutral-300 radius" style="background: var(--color-neutral-50)">.padding-xl</div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;flow&quot; style=&quot;--flow-space: var(--space-xs)&quot;&gt;
    &lt;div class=&quot;padding-tiny border border-neutral-300 radius&quot; style=&quot;background: var(--color-neutral-50)&quot;&gt;.padding-tiny&lt;/div&gt;
    &lt;div class=&quot;padding-xxs border border-neutral-300 radius&quot; style=&quot;background: var(--color-neutral-50)&quot;&gt;.padding-xxs&lt;/div&gt;
    &lt;div class=&quot;padding-xs border border-neutral-300 radius&quot; style=&quot;background: var(--color-neutral-50)&quot;&gt;.padding-xs&lt;/div&gt;
    &lt;div class=&quot;padding-s border border-neutral-300 radius&quot; style=&quot;background: var(--color-neutral-50)&quot;&gt;.padding-s&lt;/div&gt;
    &lt;div class=&quot;padding-m border border-neutral-300 radius&quot; style=&quot;background: var(--color-neutral-50)&quot;&gt;.padding-m&lt;/div&gt;
    &lt;div class=&quot;padding-l border border-neutral-300 radius&quot; style=&quot;background: var(--color-neutral-50)&quot;&gt;.padding-l&lt;/div&gt;
    &lt;div class=&quot;padding-xl border border-neutral-300 radius&quot; style=&quot;background: var(--color-neutral-50)&quot;&gt;.padding-xl&lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Axis padding</h2>
      <p>Use <code>.padding-y-{size}</code> for block-axis (top/bottom) padding and <code>.padding-x-{size}</code> for inline-axis (left/right) padding.</p>
    
      <div class="">
  <div class="flow" style="--flow-space: var(--space-xs)">
    <div class="padding-y-m padding-x-s border border-neutral-300 radius" style="background: var(--color-neutral-50)">.padding-y-m .padding-x-s — more vertical than horizontal</div>
    <div class="padding-y-xs padding-x-l border border-neutral-300 radius" style="background: var(--color-neutral-50)">.padding-y-xs .padding-x-l — more horizontal than vertical</div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;flow&quot; style=&quot;--flow-space: var(--space-xs)&quot;&gt;
    &lt;div class=&quot;padding-y-m padding-x-s border border-neutral-300 radius&quot; style=&quot;background: var(--color-neutral-50)&quot;&gt;.padding-y-m .padding-x-s — more vertical than horizontal&lt;/div&gt;
    &lt;div class=&quot;padding-y-xs padding-x-l border border-neutral-300 radius&quot; style=&quot;background: var(--color-neutral-50)&quot;&gt;.padding-y-xs .padding-x-l — more horizontal than vertical&lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Margin utilities</h2>
      <p>The same scale is available as <code>.margin-{size}</code>, <code>.margin-y-{size}</code>, and <code>.margin-x-{size}</code>. Use <code>.margin-x-auto</code> to horizontally centre a block element.</p>
    
      <div class="">
  <div style="background: var(--color-neutral-100); border-radius: var(--border-radius-m); overflow: hidden">
    <div class="margin-m background-neutral-200 padding-s radius" style="max-width: 20rem">
      .margin-m — margin on all sides
    </div>
  </div>
  <div style="background: var(--color-neutral-100); border-radius: var(--border-radius-m); overflow: hidden; margin-block-start: var(--space-s)">
    <div class="margin-x-auto background-neutral-200 padding-s radius" style="max-width: 20rem">
      .margin-x-auto — horizontally centred
    </div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div style=&quot;background: var(--color-neutral-100); border-radius: var(--border-radius-m); overflow: hidden&quot;&gt;
    &lt;div class=&quot;margin-m background-neutral-200 padding-s radius&quot; style=&quot;max-width: 20rem&quot;&gt;
      .margin-m — margin on all sides
    &lt;/div&gt;
  &lt;/div&gt;
  &lt;div style=&quot;background: var(--color-neutral-100); border-radius: var(--border-radius-m); overflow: hidden; margin-block-start: var(--space-s)&quot;&gt;
    &lt;div class=&quot;margin-x-auto background-neutral-200 padding-s radius&quot; style=&quot;max-width: 20rem&quot;&gt;
      .margin-x-auto — horizontally centred
    &lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <div class="callout wide" data-variant="brand" role="note">
    <p>For component-scoped spacing, prefer setting <code>--space-*</code> tokens directly in component CSS rather than using these utility classes. The utilities are most useful in templates and markup for quick one-off adjustments. A migration guide from the legacy <code>.padding-1</code>, <code>.padding-2</code> etc. classes is available in <code>_spacing.css</code>.</p>
  </div>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Scale reference</h2>
      <table class="">
        <thead>
          <tr>
            <th>Size name</th>
            <th>Token</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr><td><code>tiny</code></td><td><code>--space-tiny</code></td><td>Smallest spacing step.</td></tr>
          <tr><td><code>xxs</code></td><td><code>--space-xxs</code></td><td>Extra-extra-small.</td></tr>
          <tr><td><code>xs</code></td><td><code>--space-xs</code></td><td>Extra-small.</td></tr>
          <tr><td><code>s</code></td><td><code>--space-s</code></td><td>Small.</td></tr>
          <tr><td><code>m</code></td><td><code>--space-m</code></td><td>Medium (base).</td></tr>
          <tr><td><code>l</code></td><td><code>--space-l</code></td><td>Large.</td></tr>
          <tr><td><code>xl</code></td><td><code>--space-xl</code></td><td>Extra-large.</td></tr>
          <tr><td><code>xxl</code></td><td><code>--space-xxl</code></td><td>Extra-extra-large.</td></tr>
          <tr><td><code>huge</code></td><td><code>--space-huge</code></td><td>Largest spacing step.</td></tr>
        </tbody>
      </table>
  
    </div>
  </section>

</article>
{% endblock %}
