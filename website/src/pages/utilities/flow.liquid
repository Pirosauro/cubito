{% layout "layouts/base.liquid" %}
{% block title %}Flow & Gap — Cubito UI Docs{% endblock %}

{% block content %}
<article class="flow">

  <header class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/utilities/">Utilities</a></li>
        <li aria-current="page">Flow &amp; Gap</li>
      </ol>
    </nav>
    <h1>Flow &amp; Gap</h1>
    <p class="text-m color-neutral-600">Two vertical-rhythm utilities: <code>.flow</code> adds space between stacked siblings using the lobotomised owl selector, and <code>.gap</code> sets a consistent gap on flex and grid containers.</p>
  </header>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Flow</h2>
      <p>Add <code>.flow</code> to any container to apply a top margin to every sibling element after the first, using <code>* + *</code>. The default space is <code>1em</code>. Override <code>--flow-space</code> on the container or on individual children to vary the rhythm locally.</p>
    
      <div class="">
  <div class="flow" style="background: var(--color-neutral-50); padding: var(--space-m); border-radius: var(--border-radius-m)">
    <p>First paragraph — no top margin.</p>
    <p>Second paragraph — default <code>1em</code> gap above.</p>
    <p>Third paragraph — also default gap.</p>
    <p style="--flow-space: var(--space-xl)">Fourth paragraph — custom <code>--flow-space: var(--space-xl)</code> gap above.</p>
    <p>Fifth paragraph — back to default gap.</p>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;flow&quot; style=&quot;background: var(--color-neutral-50); padding: var(--space-m); border-radius: var(--border-radius-m)&quot;&gt;
    &lt;p&gt;First paragraph — no top margin.&lt;/p&gt;
    &lt;p&gt;Second paragraph — default &lt;code&gt;1em&lt;/code&gt; gap above.&lt;/p&gt;
    &lt;p&gt;Third paragraph — also default gap.&lt;/p&gt;
    &lt;p style=&quot;--flow-space: var(--space-xl)&quot;&gt;Fourth paragraph — custom &lt;code&gt;--flow-space: var(--space-xl)&lt;/code&gt; gap above.&lt;/p&gt;
    &lt;p&gt;Fifth paragraph — back to default gap.&lt;/p&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Controlling flow space</h2>
      <p>Set <code>--flow-space</code> on the <code>.flow</code> container itself to change the default spacing for all its children at once.</p>
    
      <div class="">
  <div class="flow" style="--flow-space: var(--space-l); background: var(--color-neutral-50); padding: var(--space-m); border-radius: var(--border-radius-m)">
    <p>Wider spacing — the whole stack uses <code>--flow-space: var(--space-l)</code>.</p>
    <p>Each sibling picks up the wider gap automatically.</p>
    <p>No extra classes or inline styles needed on individual children.</p>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div class=&quot;flow&quot; style=&quot;--flow-space: var(--space-l); background: var(--color-neutral-50); padding: var(--space-m); border-radius: var(--border-radius-m)&quot;&gt;
    &lt;p&gt;Wider spacing — the whole stack uses &lt;code&gt;--flow-space: var(--space-l)&lt;/code&gt;.&lt;/p&gt;
    &lt;p&gt;Each sibling picks up the wider gap automatically.&lt;/p&gt;
    &lt;p&gt;No extra classes or inline styles needed on individual children.&lt;/p&gt;
  &lt;/div&gt;</code></pre>
      </details>
  
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Gap</h2>
      <p>The <code>.gap</code> utility sets <code>gap</code> on a flex or grid container using the <code>--row-gap</code> and <code>--column-gap</code> tokens (both default to <code>var(--space-xs)</code>). Override either token inline for asymmetric gaps.</p>
    
      <div class="">
  <div style="display: flex; flex-wrap: wrap;" class="gap">
    <div style="padding: var(--space-s) var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)">Alpha</div>
    <div style="padding: var(--space-s) var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)">Beta</div>
    <div style="padding: var(--space-s) var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)">Gamma</div>
    <div style="padding: var(--space-s) var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)">Delta</div>
    <div style="padding: var(--space-s) var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)">Epsilon</div>
  </div>
      </div>

      <details class="margin-y-s">
        <summary>Show code</summary>
        <pre class="padding-m"><code>&lt;div style=&quot;display: flex; flex-wrap: wrap;&quot; class=&quot;gap&quot;&gt;
    &lt;div style=&quot;padding: var(--space-s) var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)&quot;&gt;Alpha&lt;/div&gt;
    &lt;div style=&quot;padding: var(--space-s) var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)&quot;&gt;Beta&lt;/div&gt;
    &lt;div style=&quot;padding: var(--space-s) var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)&quot;&gt;Gamma&lt;/div&gt;
    &lt;div style=&quot;padding: var(--space-s) var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)&quot;&gt;Delta&lt;/div&gt;
    &lt;div style=&quot;padding: var(--space-s) var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)&quot;&gt;Epsilon&lt;/div&gt;
  &lt;/div&gt;</code></pre>
      </details>

      {% capture demo2 %}
  <div style="display: grid; grid-template-columns: repeat(3, 1fr);" class="gap" style="--row-gap: var(--space-m); --column-gap: var(--space-s)">
    <div style="padding: var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)">One</div>
    <div style="padding: var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)">Two</div>
    <div style="padding: var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)">Three</div>
    <div style="padding: var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)">Four</div>
    <div style="padding: var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)">Five</div>
    <div style="padding: var(--space-m); background: var(--color-neutral-100); border-radius: var(--border-radius-m)">Six</div>
  </div>
      {% endcapture %}
      {% include "partials/demo.liquid", html: demo2, title: "Grid container with .gap and asymmetric row/column gap" %}
  
    </div>
  </section>

</article>
{% endblock %}
