{% layout "layouts/base.liquid" %}
{% block title %}Cubito UI — CSS Design System{% endblock %}

{% block content %}
<article class="flow">

  <div class="flow" style="padding-block-end: var(--space-l); border-block-end: var(--border-s) solid var(--color-neutral-200);">
    <h1 class="heading-xl">Cubito UI</h1>
    <p class="text-m color-neutral-600">An enterprise-grade CSS design system built on <a href="https://cube.fyi">CUBE CSS</a> and <a href="https://every-layout.dev">Every Layout</a> principles. Pure CSS, no runtime, no framework.</p>
    <div class="cluster">
      <a href="/getting-started" class="button">Get started</a>
      <a href="/components/badge" class="button" data-variant="outline">Browse components</a>
    </div>
  </div>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Design Tokens</h2>
      <p>All values are CSS custom properties, overridable at any cascade scope.</p>
      <div class="grid" style="--grid-min-item-size: 14rem;">
        <a href="/tokens/colors" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Colors</h3>
            <p class="text-s color-neutral-600">Neutral palette, semantic status colors, brand tokens.</p>
          </article>
        </a>
        <a href="/tokens/spacing" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Spacing</h3>
            <p class="text-s color-neutral-600">Fluid clamp() scale from tiny to huge.</p>
          </article>
        </a>
        <a href="/tokens/typography" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Typography</h3>
            <p class="text-s color-neutral-600">Fluid type scale, font families, line heights.</p>
          </article>
        </a>
        <a href="/tokens/motion" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Motion</h3>
            <p class="text-s color-neutral-600">Duration tokens and easing curves. Respects prefers-reduced-motion.</p>
          </article>
        </a>
        <a href="/tokens/z-index" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Z-Index</h3>
            <p class="text-s color-neutral-600">Named z-stack: dropdown → sticky → modal → tooltip.</p>
          </article>
        </a>
      </div>
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Layouts</h2>
      <p>Every Layout primitives that compose without media queries.</p>
      <div class="grid" style="--grid-min-item-size: 14rem;">
        <a href="/layouts/cluster" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Cluster</h3>
            <p class="text-s color-neutral-600">Wrapping flex row with consistent gap.</p>
          </article>
        </a>
        <a href="/layouts/cover" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Cover</h3>
            <p class="text-s color-neutral-600">Vertically centred content with pinned header/footer.</p>
          </article>
        </a>
        <a href="/layouts/frame" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Frame</h3>
            <p class="text-s color-neutral-600">Aspect-ratio crop container for media.</p>
          </article>
        </a>
        <a href="/layouts/grid" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Grid</h3>
            <p class="text-s color-neutral-600">Auto-fill responsive grid, no media queries.</p>
          </article>
        </a>
        <a href="/layouts/reel" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Reel</h3>
            <p class="text-s color-neutral-600">Horizontal scroll row.</p>
          </article>
        </a>
        <a href="/layouts/repel" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Repel</h3>
            <p class="text-s color-neutral-600">Space-between layout, stacks when narrow.</p>
          </article>
        </a>
        <a href="/layouts/sidebar" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Sidebar</h3>
            <p class="text-s color-neutral-600">Fixed sidebar + flexible main content.</p>
          </article>
        </a>
        <a href="/layouts/sticky-bar" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Sticky Bar</h3>
            <p class="text-s color-neutral-600">Fixed top or bottom full-width bar.</p>
          </article>
        </a>
        <a href="/layouts/switcher" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Switcher</h3>
            <p class="text-s color-neutral-600">Horizontal ↔ stacked at a container threshold.</p>
          </article>
        </a>
      </div>
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Components</h2>
      <p>Block-level components styled entirely through CSS custom properties.</p>
      <div class="grid" style="--grid-min-item-size: 14rem;">
                <a href="/components/avatar" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Avatar</h3>
            <p class="text-s color-neutral-600">User representation with status indicator.</p>
          </article>
        </a>
                <a href="/components/badge" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Badge</h3>
            <p class="text-s color-neutral-600">Compact pill for status and counts.</p>
          </article>
        </a>
                <a href="/components/banner" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Banner</h3>
            <p class="text-s color-neutral-600">Full-width sitewide announcement.</p>
          </article>
        </a>
                <a href="/components/breadcrumb" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Breadcrumb</h3>
            <p class="text-s color-neutral-600">Hierarchical navigation aid.</p>
          </article>
        </a>
                <a href="/components/callout" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Callout</h3>
            <p class="text-s color-neutral-600">Inline notification block.</p>
          </article>
        </a>
                <a href="/components/card" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Card</h3>
            <p class="text-s color-neutral-600">Versatile content container.</p>
          </article>
        </a>
                <a href="/components/data-list" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Data List</h3>
            <p class="text-s color-neutral-600">Structured key/value pairs.</p>
          </article>
        </a>
                <a href="/components/dialog" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Dialog</h3>
            <p class="text-s color-neutral-600">Native modal dialog.</p>
          </article>
        </a>
                <a href="/components/empty-state" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Empty State</h3>
            <p class="text-s color-neutral-600">Zero-results placeholder.</p>
          </article>
        </a>
                <a href="/components/footnote" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Footnote</h3>
            <p class="text-s color-neutral-600">Numbered reference list.</p>
          </article>
        </a>
                <a href="/components/hero" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Hero</h3>
            <p class="text-s color-neutral-600">Page intro section.</p>
          </article>
        </a>
                <a href="/components/pagination" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Pagination</h3>
            <p class="text-s color-neutral-600">Page navigation with prev/next.</p>
          </article>
        </a>
                <a href="/components/pictogram" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Pictogram</h3>
            <p class="text-s color-neutral-600">Icon + label feature rows.</p>
          </article>
        </a>
                <a href="/components/price" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Price</h3>
            <p class="text-s color-neutral-600">Monetary display with sale support.</p>
          </article>
        </a>
                <a href="/components/progress-bar" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Progress Bar</h3>
            <p class="text-s color-neutral-600">Accessible labelled progress indicator.</p>
          </article>
        </a>
                <a href="/components/prose" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Prose</h3>
            <p class="text-s color-neutral-600">Long-form reading styles.</p>
          </article>
        </a>
                <a href="/components/rating" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Rating</h3>
            <p class="text-s color-neutral-600">CSS-only star rating.</p>
          </article>
        </a>
                <a href="/components/stepper" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Stepper</h3>
            <p class="text-s color-neutral-600">Quantity input control.</p>
          </article>
        </a>
                <a href="/components/tabs" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Tabs</h3>
            <p class="text-s color-neutral-600">WAI-ARIA tabbed interface.</p>
          </article>
        </a>
                <a href="/components/tag" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Tag</h3>
            <p class="text-s color-neutral-600">Taxonomy labels and selectable chips.</p>
          </article>
        </a>
                <a href="/components/toast" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Toast</h3>
            <p class="text-s color-neutral-600">Dismissible notification overlay.</p>
          </article>
        </a>
      </div>
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Base Elements</h2>
      <p>Styled HTML element defaults that work without class names.</p>
      <div class="grid" style="--grid-min-item-size: 14rem;">
                <a href="/base/button" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Button</h3>
            <p class="text-s color-neutral-600">Variants, states, loading, icon support.</p>
          </article>
        </a>
                <a href="/base/form" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Form</h3>
            <p class="text-s color-neutral-600">Input, select, textarea, checkbox, radio, fieldset.</p>
          </article>
        </a>
                <a href="/base/table" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Table</h3>
            <p class="text-s color-neutral-600">Striped, bordered, responsive tables.</p>
          </article>
        </a>
                <a href="/base/nav" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Nav</h3>
            <p class="text-s color-neutral-600">Navigation element with main and sidebar variants.</p>
          </article>
        </a>
                <a href="/base/code" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Code</h3>
            <p class="text-s color-neutral-600">Inline code, code blocks, keyboard shortcuts.</p>
          </article>
        </a>
                <a href="/base/tooltip" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Tooltip</h3>
            <p class="text-s color-neutral-600">CSS-only tooltip positioning.</p>
          </article>
        </a>
      </div>
    </div>
  </section>

  <section>
    <div class="flow" style="--flow-space: var(--space-s);">
      <h2 class="heading-l">Utilities</h2>
      <p>Single-purpose helpers at the highest cascade layer.</p>
      <div class="grid" style="--grid-min-item-size: 14rem;">
                <a href="/utilities/accessibility" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Accessibility</h3>
            <p class="text-s color-neutral-600">Skip link, sr-only.</p>
          </article>
        </a>
                <a href="/utilities/animation" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Animation</h3>
            <p class="text-s color-neutral-600">blink, fade-in, slide-up.</p>
          </article>
        </a>
                <a href="/utilities/border" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Border</h3>
            <p class="text-s color-neutral-600">Border and radius utilities.</p>
          </article>
        </a>
                <a href="/utilities/color" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Color</h3>
            <p class="text-s color-neutral-600">Foreground and background color helpers.</p>
          </article>
        </a>
                <a href="/utilities/flow" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Flow & Gap</h3>
            <p class="text-s color-neutral-600">Vertical rhythm and flex/grid gap.</p>
          </article>
        </a>
                <a href="/utilities/shadow" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Shadow</h3>
            <p class="text-s color-neutral-600">Box shadow and text shadow.</p>
          </article>
        </a>
                <a href="/utilities/skeleton" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Skeleton</h3>
            <p class="text-s color-neutral-600">Loading placeholder.</p>
          </article>
        </a>
                <a href="/utilities/spacing" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Spacing</h3>
            <p class="text-s color-neutral-600">Padding and margin utilities.</p>
          </article>
        </a>
                <a href="/utilities/typography" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Typography</h3>
            <p class="text-s color-neutral-600">Heading, text size, weight, alignment.</p>
          </article>
        </a>
                <a href="/utilities/wrapper" class="card" data-layout="default">
          <article class="flow">
            <h3 class="heading-s">Wrapper</h3>
            <p class="text-s color-neutral-600">Max-width container.</p>
          </article>
        </a>
      </div>
    </div>
  </section>

</article>
{% endblock %}
