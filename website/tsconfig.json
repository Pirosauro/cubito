{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "paths": {
      "~/*": ["./src/*"]
    },
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "exclude": ["node_modules", "**/*.test.ts"],
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
